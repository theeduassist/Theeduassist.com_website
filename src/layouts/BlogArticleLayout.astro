---
import Layout from './Layout.astro';
import ReadingProgressBar from '../components/blog/ReadingProgressBar.astro';
import AIPageAssistBar from '../components/blog/AIPageAssistBar.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  type?: string;
  jsonLd?: any[];
}

const { title, description, canonicalPath, ogImage, type = "article", jsonLd = [] } = Astro.props;
---
<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  type={type}
  jsonLd={jsonLd}
>
  <ReadingProgressBar />

  <main class="bg-white min-h-screen pb-24">
    <slot />
  </main>

  <!-- AIPageAssistBar needs to be globally available on blog pages but not rendered dynamically if missing -->
  <AIPageAssistBar />
</Layout>
