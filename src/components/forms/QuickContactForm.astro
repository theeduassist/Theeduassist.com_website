---
import FormField from './FormField.astro';
import TextAreaField from './TextAreaField.astro';
import SelectField from './SelectField.astro';
import HiddenTrackingFields from './HiddenTrackingFields.astro';

const serviceOptions = [
  { value: 'Course Creation & Curriculum Design', label: 'Course Creation & Curriculum Design' },
  { value: 'Kajabi Website & Course Setup', label: 'Kajabi Website & Course Setup' },
  { value: 'LMS Implementation & Migration', label: 'LMS Implementation & Migration' },
  { value: 'AI-Powered E-Learning Support', label: 'AI-Powered E-Learning Support' },
  { value: 'Content Conversion', label: 'Content Conversion' },
  { value: 'Funnels & Automation', label: 'Funnels & Automation' },
  { value: 'Ongoing Support & Maintenance', label: 'Ongoing Support & Maintenance' },
  { value: 'Not Sure Yet', label: 'Not Sure Yet' },
  { value: 'Other', label: 'Other' },
];
---

<!-- TODO: Implement backend integration. Using mailto: fallback for now. -->
<form class="space-y-5" id="quick-contact-form">
  <HiddenTrackingFields formType="contact" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <FormField name="fullName" label="Name" required={true} placeholder="Your Name" />
    <FormField name="email" label="Email Address" type="email" required={true} placeholder="Your Email" />
  </div>

  <FormField name="company" label="Company / Organization" placeholder="Company Name" />

  <SelectField name="serviceNeeded" label="What do you need help with?" options={serviceOptions} required={true} />

  <TextAreaField name="message" label="Message" required={true} placeholder="How can we help?" rows={5} />

  <p class="text-xs text-slate-500">
    We use your details only to review your request and respond with the right next step. Do not upload confidential files through this form.
  </p>

  <button type="submit" class="bg-[#77BA55] hover:bg-green-600 text-white px-6 py-3 rounded-md font-medium transition-colors w-full md:w-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600" id="submit-contact-btn">
    Send Message via Email
  </button>
</form>

<script>
  document.getElementById('quick-contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);

    const name = formData.get('fullName') || '';
    const email = formData.get('email') || '';
    const company = formData.get('company') || '';
    const service = formData.get('serviceNeeded') || '';
    const message = formData.get('message') || '';

    const body = `Name: ${name}\nEmail: ${email}\nCompany: ${company}\nService Needed: ${service}\n\nMessage:\n${message}`;

    // Redirect to mailto safely encoding the payload
    window.location.href = `mailto:Info@theeduassist.com?subject=Quick Contact Request&body=${encodeURIComponent(body)}`;

    const btn = document.getElementById('submit-contact-btn') as HTMLButtonElement;
    if(btn) {
      btn.innerText = 'Opening Email App...';
      setTimeout(() => {
        window.location.href = '/thank-you/';
      }, 1000);
    }
  });
</script>
