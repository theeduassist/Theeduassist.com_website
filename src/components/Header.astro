---
import { site } from '../data/site';
import { navigation } from '../data/navigation';
import MobileMenu from './layout/MobileMenu.astro';
---
<header class="bg-white border-b border-brand-border sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center relative">
        <a href="/" class="flex items-center space-x-2 focus-ring" aria-label="TheEduAssist Home">
            <img src="/brand/theeduassist-logo-wordmark.svg" alt="TheEduAssist e-learning design agency logo" class="h-10 w-auto" />
        </a>
        <nav class="hidden md:flex space-x-6 items-center">
            {navigation.header.map((item) => (
                <a href={item.href} class="text-brand-textMuted hover:text-brand-primary font-medium transition-colors focus-ring px-2 py-1">{item.label}</a>
            ))}
        </nav>
        <div class="hidden md:flex">
            <a href="/book-free-audit/" class="bg-brand-accent text-white px-5 py-2 rounded-md font-medium hover:bg-brand-navy hover-lift focus-ring">Book Free Audit</a>
        </div>
        <MobileMenu />
    </div>
</header>
