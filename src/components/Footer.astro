---
import { getSiteSettings } from '../sanity/queries';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const navigation = {
    footerCompanyLinks: [
        { label: 'Home', href: '/' },
        { label: 'Services', href: '/services/' },
        { label: 'Kajabi Services', href: '/kajabi-services/' },
        { label: 'Blog', href: '/blog/' },
        { label: 'Case Studies', href: '/case-studies/' },
        { label: 'About Us', href: '/about/' },
        { label: 'Contact Us', href: '/contact/' },
    ],
    footerLegalLinks: [
        { label: 'Privacy Policy', href: '/privacy-policy/' },
        { label: 'Terms & Conditions', href: '/terms-and-conditions/' },
        { label: 'Disclaimer', href: '/disclaimer/' },
        { label: 'Editorial Policy', href: '/editorial-policy/' },
        { label: 'AI Use Policy', href: '/ai-use-policy/' },
        { label: 'Accessibility Statement', href: '/accessibility-statement/' },
        { label: 'Cookie Policy', href: '/cookie-policy/' },
    ]
};
---
<footer class="bg-brand-primary text-slate-300 py-12 border-t border-brand-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-8">
        <div>
            <div class="mb-4">
                <img src="/brand/theeduassist-logo-wordmark.svg" alt="TheEduAssist Logo" class="h-12 w-auto brightness-0 invert opacity-90" />
            </div>
            <p class="mb-4 leading-relaxed">TheEduAssist helps teams design, build, migrate, and improve online learning across LMS platforms, course websites, Kajabi, and AI-supported learning workflows.</p>

            <p class="mb-2">Email: <a href="mailto:Info@theeduassist.com" class="text-brand-accent hover:text-white transition-colors focus-ring rounded-sm">Info@theeduassist.com</a></p>

            <div class="flex space-x-4 mt-6">
                <a href="https://www.linkedin.com/company/theeduassist" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring rounded-sm" aria-label="LinkedIn">LinkedIn</a>
                <a href="https://www.facebook.com/people/Theeduassist/61576126813447/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring rounded-sm" aria-label="Facebook">Facebook</a>
                <a href="https://www.instagram.com/theeduassist" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring rounded-sm" aria-label="Instagram">Instagram</a>
            </div>

            <div class="mt-8">
                <h3 class="text-white font-bold mb-4 text-lg">Ready to improve your eLearning?</h3>
                <a href="/book-free-audit/" class="inline-block bg-brand-accent text-brand-navy px-5 py-2 rounded-md font-medium hover-lift click-press focus-ring transition-colors hover:bg-white">Get a Free Consultation</a>
            </div>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Services</h3>
            <ul class="space-y-2">
                <li><a href="/services/custom-elearning-development/" class="hover:text-white">Custom eLearning Development</a></li>
                <li><a href="/services/" class="hover:text-white">Gamified Learning</a></li>
                <li><a href="/services/" class="hover:text-white">Microlearning & Microsimulations</a></li>
                <li><a href="/services/" class="hover:text-white">Audio & Video Production</a></li>
                <li><a href="/services/" class="hover:text-white">Rapid eLearning</a></li>
                <li><a href="/services/" class="hover:text-white">Mobile Learning Solutions</a></li>
                <li><a href="/services/lms-implementation-migration/" class="hover:text-white">LMS Implementation and Migration</a></li>
                <li><a href="/services/" class="hover:text-white">eLearning Localization</a></li>
                <li><a href="/services/" class="hover:text-white">Legacy Content Conversion</a></li>
                <li><a href="/services/" class="hover:text-white">AR & VR Solutions</a></li>
                <li><a href="/services/" class="hover:text-white">Dashboards & Analytics</a></li>
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Training Solutions</h3>
            <ul class="space-y-2">
                <li><a href="/services/" class="hover:text-white">Sales Training</a></li>
                <li><a href="/services/" class="hover:text-white">Induction & Onboarding Training</a></li>
                <li><a href="/services/" class="hover:text-white">Leadership Training</a></li>
                <li><a href="/services/" class="hover:text-white">Professional Skills Training</a></li>
                <li><a href="/services/" class="hover:text-white">Product Training</a></li>
                <li><a href="/services/" class="hover:text-white">Soft Skills Training</a></li>
                <li><a href="/services/" class="hover:text-white">Customer Service Training</a></li>
                <li><a href="/services/" class="hover:text-white">Field & Frontline Staff Training</a></li>
                <li><a href="/services/" class="hover:text-white">Truck Driver Training (Canada & USA)</a></li>
                <li><a href="/services/" class="hover:text-white">Franchise Training</a></li>
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Company</h3>
            <ul class="space-y-2 mb-8">
                {navigation.footerCompanyLinks?.map((item) => (
                    <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
                ))}
            </ul>
            <h3 class="text-white font-bold mb-4">Legal & Trust</h3>
            <ul class="space-y-2">
                {navigation.footerLegalLinks.map((item) => (
                    <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
                ))}
            </ul>
        </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-brand-navy text-center text-sm">
        &copy; 2026, {site?.name || 'TheEduAssist'}. All rights reserved.
    </div>
</footer>
