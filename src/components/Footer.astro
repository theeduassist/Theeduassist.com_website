---
import { getSiteSettings } from '../sanity/queries';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const navigation = {
    footerServicesLinks: [
        { label: 'Course Creation', href: '/services/custom-elearning-development/' },
        { label: 'Kajabi Setup', href: '/kajabi-services/' },
        { label: 'LMS Migration', href: '/services/lms-implementation-migration/' },
        { label: 'AI Assistance', href: '/services/ai-assistance/' },
        { label: 'Funnels & Automation', href: '/services/' },
        { label: 'Ongoing Support', href: '/services/' },
    ],
    footerCompanyLinks: [
        { label: 'About', href: '/about/' },
        { label: 'Case Studies', href: '/case-studies/' },
        { label: 'Blog', href: '/blog/' },
        { label: 'Contact', href: '/contact/' },
        { label: 'Privacy Policy', href: '/privacy-policy/' },
        { label: 'Terms', href: '/terms-and-conditions/' },
    ]
};
---
<footer class="bg-brand-primary text-slate-300 py-16 border-t border-brand-navy relative overflow-hidden">
    <!-- Decorative subtle background pattern/glow -->
    <div class="absolute -bottom-48 -right-48 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-8">
        <div class="md:col-span-2 lg:col-span-1">
            <div class="mb-6 flex items-center space-x-3">
                <img src="/brand/theeduassist-logo.svg" alt="TheEduAssist Logo" class="h-10 w-auto brightness-0 invert" />
                <div class="flex flex-col">
                    <span class="font-bold text-white text-xl leading-tight">TheEduAssist</span>
                    <span class="text-xs text-brand-accent font-medium uppercase tracking-wider">E-Learning Design Agency</span>
                </div>
            </div>
            <p class="mb-6 leading-relaxed text-sm text-slate-400">TheEduAssist helps creators, educators, and training teams build complete online course systems, Kajabi platforms, and AI-supported learning workflows.</p>

            <p class="mb-2 text-sm">Email: <a href="mailto:Info@theeduassist.com" class="text-brand-accent hover:text-white transition-colors focus-ring rounded-sm">Info@theeduassist.com</a></p>

            <div class="flex space-x-4 mt-6">
                <a href="https://www.linkedin.com/company/theeduassist" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors focus-ring rounded-sm" aria-label="LinkedIn">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                <a href="https://www.facebook.com/people/Theeduassist/61576126813447/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors focus-ring rounded-sm" aria-label="Facebook">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
                </a>
                <a href="https://www.instagram.com/theeduassist" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors focus-ring rounded-sm" aria-label="Instagram">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4s1.791-4 4-4 4 1.79 4 4-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
            </div>
        </div>
        <div>
            <h3 class="text-white font-bold mb-6 tracking-wide uppercase text-sm">Services</h3>
            <ul class="space-y-3 text-sm">
                {navigation.footerServicesLinks.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-white transition-colors">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-6 tracking-wide uppercase text-sm">Company</h3>
            <ul class="space-y-3 text-sm">
                {navigation.footerCompanyLinks?.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-white transition-colors">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div class="bg-brand-navy/50 p-6 rounded-xl border border-white/5 h-fit">
            <h3 class="text-white font-bold mb-3 text-lg">Ready to turn your expertise into a launch-ready learning system?</h3>
            <p class="text-sm text-slate-400 mb-6">Book a free course audit to map out your strategy.</p>
            <a href="/book-free-audit/" class="block text-center bg-brand-accent text-brand-navy px-5 py-3 rounded-md font-bold hover-lift click-press focus-ring transition-colors hover:bg-white shadow-md">Book Free Audit</a>
        </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16 pt-8 border-t border-white/10 text-center text-sm text-slate-500">
        &copy; 2026, TheEduAssist. All rights reserved.
    </div>
</footer>
