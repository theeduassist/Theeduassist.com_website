---
import { getSiteSettings } from '../sanity/queries';
import { aiAssistants } from '../data/aiAssistants';
import { shareLinks } from '../data/shareLinks';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const navigation = {
    services: [
        { label: 'Course Creation', href: '/services/' },
        { label: 'Curriculum Design', href: '/services/' },
        { label: 'Kajabi Setup', href: '/kajabi-services/' },
        { label: 'LMS Migration', href: '/services/lms-implementation-migration/' },
        { label: 'Content Conversion', href: '/services/' },
        { label: 'Funnels & Automation', href: '/services/' },
        { label: 'Ongoing Support', href: '/services/' }
    ],
    solutions: [
        { label: 'For Creators & Coaches', href: '/' },
        { label: 'For Consultants', href: '/' },
        { label: 'For Educators', href: '/' },
        { label: 'For Training Companies', href: '/' },
        { label: 'For Online Academies', href: '/' },
        { label: 'For Businesses', href: '/' }
    ],
    resources: [
        { label: 'Blog', href: '/blog/' },
        { label: 'Case Studies', href: '/case-studies/' },
        { label: 'Guides', href: '/resources/' },
        { label: 'FAQs', href: '/contact/' },
        { label: 'AI Summary', href: '/ai-summary.md' },
        { label: 'Contact', href: '/contact/' }
    ],
    company: [
        { label: 'About', href: '/about/' },
        { label: 'Services', href: '/services/' },
        { label: 'Careers', href: '/careers/' },
        { label: 'Privacy Policy', href: '/privacy-policy/' },
        { label: 'Terms and Conditions', href: '/terms-and-conditions/' }
    ]
};
---
<footer class="bg-brand-navy text-slate-300 py-16 border-t border-brand-border/20 relative overflow-hidden">
    <!-- Top Footer CTA -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
        <div class="bg-brand-primary p-8 md:p-12 rounded-3xl border border-white/10 flex flex-col md:flex-row items-center justify-between gap-6 shadow-xl relative overflow-hidden">
            <div class="absolute right-0 top-0 w-64 h-64 bg-brand-accent/20 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
            <div class="relative z-10 text-center md:text-left">
                <h3 class="text-2xl md:text-3xl font-bold text-white mb-2">Ready to build a better learning experience?</h3>
                <p class="text-slate-300">Book a free audit to review your current content or Kajabi setup.</p>
            </div>
            <a href="/book-free-audit/" class="relative z-10 shrink-0 bg-brand-accent text-white px-8 py-4 rounded-md font-bold text-lg hover-lift click-press focus-ring transition-all hover:bg-white hover:text-brand-navy shadow-lg text-center">
                Book Free Audit
            </a>
        </div>
    </div>

    <!-- 4-Column Navigation -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 md:grid-cols-4 gap-8 mb-16">
        <div>
            <h4 class="text-white font-bold mb-6 tracking-wider uppercase text-sm">Services</h4>
            <ul class="space-y-3 text-sm">
                {navigation.services.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-brand-accent transition-colors focus-ring inline-block">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h4 class="text-white font-bold mb-6 tracking-wider uppercase text-sm">Solutions</h4>
            <ul class="space-y-3 text-sm">
                {navigation.solutions.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-brand-accent transition-colors focus-ring inline-block">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h4 class="text-white font-bold mb-6 tracking-wider uppercase text-sm">Resources</h4>
            <ul class="space-y-3 text-sm">
                {navigation.resources.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-brand-accent transition-colors focus-ring inline-block">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h4 class="text-white font-bold mb-6 tracking-wider uppercase text-sm">Company</h4>
            <ul class="space-y-3 text-sm">
                {navigation.company.map((item) => (
                    <li><a href={item.href} class="text-slate-400 hover:text-brand-accent transition-colors focus-ring inline-block">{item.label}</a></li>
                ))}
            </ul>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="border-t border-white/10 pt-8 pb-12 flex flex-col items-center">

            <!-- AI Utility Section -->
            <div class="w-full max-w-3xl text-center mb-10">
                <h4 class="text-white font-medium text-lg mb-4">Ask AI about TheEduAssist:</h4>
                <div class="flex flex-wrap justify-center gap-3">
                    {aiAssistants.map(ai => (
                        <button
                            type="button"
                            class="ai-utility-btn flex items-center space-x-2 bg-white/5 border border-white/10 hover:border-brand-accent hover:bg-brand-accent/10 px-4 py-2 rounded-full text-sm font-medium text-slate-300 hover:text-white transition-all focus-ring"
                            data-ai-url={ai.url}
                        >
                            <span>{ai.name}</span>
                        </button>
                    ))}
                </div>
            </div>

            <!-- Share Utility Section -->
            <div class="w-full max-w-3xl text-center">
                <h4 class="text-white font-medium text-lg mb-4">Share this:</h4>
                <div class="flex flex-wrap justify-center gap-3">
                    {shareLinks.map(link => (
                        <button
                            type="button"
                            class="share-utility-btn flex items-center space-x-2 bg-white/5 border border-white/10 hover:border-white/30 hover:bg-white/10 px-4 py-2 rounded-full text-sm font-medium text-slate-300 hover:text-white transition-all focus-ring"
                            data-share-id={link.id}
                        >
                            <span>{link.name}</span>
                        </button>
                    ))}
                    <button type="button" id="copy-link-btn" class="flex items-center space-x-2 bg-white/5 border border-white/10 hover:border-white/30 hover:bg-white/10 px-4 py-2 rounded-full text-sm font-medium text-slate-300 hover:text-white transition-all focus-ring">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                        <span>Copy Link</span>
                    </button>
                </div>
            </div>

        </div>

        <!-- Bottom Copyright and Social Links -->
        <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-slate-500">
            <div class="flex items-center space-x-3">
                <img src="/brand/theeduassist-logo-mark.svg" alt="TheEduAssist Logo Mark" class="w-6 h-6 brightness-0 invert opacity-50" />
                <span>&copy; 2026, TheEduAssist. All rights reserved.</span>
            </div>

            <div class="flex space-x-6">
                <a href="https://www.linkedin.com/company/theeduassist" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring rounded-sm" aria-label="LinkedIn">
                    LinkedIn
                </a>
                <a href="https://www.instagram.com/theeduassist" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring rounded-sm" aria-label="Instagram">
                    Instagram
                </a>
                <a href="https://www.facebook.com/people/Theeduassist/61576126813447/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring rounded-sm" aria-label="Facebook">
                    Facebook
                </a>
            </div>
        </div>
    </div>
</footer>

<div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>

<script>
    import { generatePrompt } from './ai/AIAssistClient';
    import { shareLinks } from '../data/shareLinks';

    function showToast(message: string) {
        const container = document.getElementById('toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = 'bg-brand-navy border border-brand-accent/50 text-white px-4 py-3 rounded shadow-lg transform transition-all duration-300 translate-y-full opacity-0 flex items-center space-x-2';
        toast.innerHTML = `
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-sm font-medium">${message}</span>
        `;

        container.appendChild(toast);

        // Animate in
        requestAnimationFrame(() => {
            toast.classList.remove('translate-y-full', 'opacity-0');
        });

        // Remove after delay
        setTimeout(() => {
            toast.classList.add('translate-y-full', 'opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }

    document.addEventListener('DOMContentLoaded', () => {
        // AI Buttons
        const aiBtns = document.querySelectorAll('.ai-utility-btn');
        aiBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const url = target.dataset.aiUrl || '';
                const prompt = generatePrompt('summarize_page');

                try {
                    await navigator.clipboard.writeText(prompt);
                    showToast('Prompt copied. Paste it into your AI assistant to continue.');
                    window.open(url, '_blank', 'noopener,noreferrer');
                } catch (err) {
                    console.error('Clipboard error:', err);
                    alert('Failed to copy prompt to clipboard.');
                }
            });
        });

        // Share Buttons
        const shareBtns = document.querySelectorAll('.share-utility-btn');
        shareBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const id = target.dataset.shareId;
                const linkDef = shareLinks.find(l => l.id === id);
                if (linkDef) {
                    const currentUrl = window.location.href;
                    const title = document.title;
                    const shareUrl = linkDef.getShareUrl(currentUrl, title);
                    window.open(shareUrl, '_blank', 'noopener,noreferrer,width=600,height=400');
                }
            });
        });

        // Copy Link
        const copyBtn = document.getElementById('copy-link-btn');
        if (copyBtn) {
            copyBtn.addEventListener('click', async () => {
                try {
                    await navigator.clipboard.writeText(window.location.href);
                    showToast('Page link copied to clipboard.');
                } catch (err) {
                    console.error('Clipboard error:', err);
                }
            });
        }
    });
</script>
