---
import { getSiteSettings, getAllPages } from '../sanity/queries';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const pages = await getAllPages();
const navigation = pages && pages.length > 0 ? {
    footerCompanyLinks: pages.slice(0,8).map(p => ({ label: p.title, href: `/${p.slug?.current || ''}/` })),
    footerLegalLinks: []
} : {
    footerCompanyLinks: [
        { label: 'Home', href: '/' },
        { label: 'Blogs', href: '/blog/' },
        { label: 'Career', href: '/careers/' },
        { label: 'About Us', href: '/about/' },
        { label: 'Contact Us', href: '/contact/' },
        { label: 'Case Studies', href: '/case-studies/' },
        { label: 'Terms & Conditions', href: '/terms-and-conditions/' },
    ],
    footerLegalLinks: [
        { label: 'Privacy Policy', href: '/privacy-policy/' },
        { label: 'Disclaimer', href: '/disclaimer/' },
        { label: 'Editorial Policy', href: '/editorial-policy/' },
        { label: 'AI Use Policy', href: '/ai-use-policy/' },
        { label: 'Accessibility Statement', href: '/accessibility-statement/' },
    ]
};
---
<footer class="bg-brand-primary text-slate-300 py-12 border-t border-brand-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="space-y-6">
            <div>
                <img src="/brand/theeduassist-logo-wordmark.svg" alt="TheEduAssist Logo" class="h-12 w-auto brightness-0 invert opacity-90" />
            </div>
            <p class="mb-4">TheEduAssist delivers fast, flexible, and impactful eLearning solutions that help teams upskill, adapt, and succeed in a changing business world.</p>
            <p>Email: <a href={`mailto:${site.email}`} class="text-brand-accent hover:text-white">{site.email}</a></p>
            <!-- Verify address before launch -->
            <!-- <p>9030 35th Ave SW, Seattle, United States</p> -->
                <div class="flex space-x-4 mt-6">
                    <a href={site?.social?.linkedIn || '#'} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="LinkedIn">LinkedIn</a>
                    <a href={site?.social?.facebook || '#'} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="Facebook">Facebook</a>
                    <a href={site?.social?.instagram || '#'} target="_blank" rel="noopener noreferrer" class="hover:text-white" aria-label="Instagram">Instagram</a>
                </div>
                <p>Email: <a href={`mailto:${site?.email || 'info@theeduassist.com'}`} class="text-brand-accent hover:text-white">{site?.email || 'info@theeduassist.com'}</a></p>
            <div class="mt-8">
                <h3 class="text-white font-bold mb-4">Ready to improve your eLearning?</h3>
                <a href="/book-free-audit/" class="inline-block bg-brand-accent text-white px-5 py-2 rounded-md font-medium hover:bg-white hover:text-brand-primary transition-colors focus-ring">Get a Free Consultation</a>
            </div>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Services</h3>
            <ul class="space-y-2">
                <li><a href="/services/custom-elearning-development/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">Custom eLearning Development</a></li>
                <li><a href="/services/lms-implementation-migration/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">LMS Implementation & Migration</a></li>
                <li><a href="/services/ai-powered-elearning/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">AI-Powered eLearning</a></li>
                <li><a href="/kajabi-services/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">Kajabi Services</a></li>
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Company</h3>
            <ul class="space-y-2 mb-8">
                {(Array.isArray(navigation?.header) ? navigation.header : []).map((item) => (
                    <li><a href={item.href} class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Legal & Trust</h3>
            <ul class="space-y-2">
                {(Array.isArray(navigation?.footerLegalLinks) ? navigation.footerLegalLinks : []).map((item) => (
                    <li><a href={item.href} class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">{item.label}</a></li>
                ))}
            </ul>
        </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-brand-navy text-center text-sm text-slate-400">
        &copy; 2026, TheEduAssist. All rights reserved.
    </div>
</footer>
