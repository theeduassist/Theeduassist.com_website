---
import { site } from '../data/site';
import { navigation } from '../data/navigation';
---
<footer class="bg-brand-primary text-slate-300 py-12 border-t border-brand-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="space-y-6">
            <div>
                <img src="/brand/theeduassist-logo-wordmark.svg" alt="TheEduAssist Logo" class="h-12 w-auto brightness-0 invert opacity-90" />
            </div>
            <p class="leading-relaxed">TheEduAssist delivers fast, flexible, and impactful eLearning solutions that help teams upskill, adapt, and succeed in a changing business world.</p>
            <p>Email: <a href="mailto:Info@theeduassist.com" class="text-brand-accent hover:text-white transition-colors focus-ring px-1">Info@theeduassist.com</a></p>
            <div class="flex space-x-5 mt-6">
                <a href="https://www.linkedin.com/company/theeduassist" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring p-1 rounded" aria-label="LinkedIn">
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                </a>
                <a href="https://www.facebook.com/people/Theeduassist/61576126813447/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring p-1 rounded" aria-label="Facebook">
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                  </svg>
                </a>
                <a href="https://www.instagram.com/theeduassist" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors focus-ring p-1 rounded" aria-label="Instagram">
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                  </svg>
                </a>
            </div>
            <div class="mt-8">
                <h3 class="text-white font-bold mb-4">Ready to improve your eLearning?</h3>
                <a href="/book-free-audit/" class="inline-block bg-brand-accent text-white px-5 py-2 rounded-md font-medium hover:bg-white hover:text-brand-primary transition-colors focus-ring">Get a Free Consultation</a>
            </div>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Services</h3>
            <ul class="space-y-2">
                <li><a href="/services/custom-elearning-development/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">Custom eLearning Development</a></li>
                <li><a href="/services/lms-implementation-migration/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">LMS Implementation & Migration</a></li>
                <li><a href="/services/ai-powered-elearning/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">AI-Powered eLearning</a></li>
                <li><a href="/kajabi-services/" class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">Kajabi Services</a></li>
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Company</h3>
            <ul class="space-y-2 mb-8">
                {navigation.header.map((item) => (
                    <li><a href={item.href} class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Legal & Trust</h3>
            <ul class="space-y-2">
                {navigation.footerLegalLinks?.map((item) => (
                    <li><a href={item.href} class="hover:text-white transition-colors focus-ring px-1 -mx-1 rounded">{item.label}</a></li>
                ))}
            </ul>
        </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-brand-navy text-center text-sm text-slate-400">
        &copy; 2026, TheEduAssist. All rights reserved.
    </div>
</footer>
