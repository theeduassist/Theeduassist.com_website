---
import { site } from '../data/site';
import { navigation } from '../data/navigation';
---
<footer class="bg-slate-900 text-slate-300 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
            <div class="text-2xl font-bold text-white mb-4">{site.name}</div>
            <p class="mb-4">Custom eLearning, Kajabi, and LMS Solutions Built to Launch Faster</p>
            <p>Email: <a href={`mailto:${site.email}`} class="text-blue-400">{site.email}</a></p>
            <p>Serving clients remotely.</p>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Quick Links</h3>
            <ul class="space-y-2">
                {navigation.footerQuickLinks.map((item) => (
                    <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
                ))}
            </ul>
        </div>
        <div>
            <h3 class="text-white font-bold mb-4">Ready to improve your eLearning?</h3>
            <a href="/book-free-audit/" class="inline-block bg-blue-600 text-white px-5 py-2 rounded-md font-medium hover:bg-blue-700">Book Free Audit</a>
        </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-slate-800 text-center text-sm">
        &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
    </div>
</footer>
