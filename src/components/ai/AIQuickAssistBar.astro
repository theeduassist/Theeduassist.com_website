---
import { aiAssistants } from '../../data/aiAssistants';

const actions = [
    { id: 'summarize_page', label: 'Summarize' },
    { id: 'explain_service', label: 'Explain' },
    { id: 'help_me_choose', label: 'Help Me Choose' },
    { id: 'create_action_plan', label: 'Action Plan' }
];

const defaultAssistant = aiAssistants[0]; // ChatGPT
---

<div id="ai-quick-assist-bar" class="hidden bg-brand-softBg border-b border-brand-border/50 py-2 px-4 sm:px-6 lg:px-8 text-sm transition-all duration-300 relative z-40">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
        <div class="flex items-center text-slate-700">
            <svg class="w-4 h-4 mr-2 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            <span class="hidden md:inline">Need help understanding this page? Ask AI to summarize, explain, or turn it into an action plan.</span>
            <span class="md:hidden">Ask AI to understand this page.</span>
        </div>

        <div class="flex items-center gap-2 overflow-x-auto no-scrollbar w-full sm:w-auto pb-1 sm:pb-0">
            {actions.map(action => (
                <button
                    class="ai-quick-action whitespace-nowrap px-3 py-1 bg-white hover:bg-brand-primary hover:text-white text-brand-primary text-xs font-medium rounded-full border border-brand-primary/20 transition-colors focus-ring"
                    data-action={action.id}
                    data-url={defaultAssistant.url}
                    data-name={defaultAssistant.name}
                >
                    {action.label}
                </button>
            ))}

            <button id="dismiss-ai-bar" class="ml-2 text-slate-400 hover:text-slate-600 focus:outline-none p-1 rounded-full" aria-label="Dismiss AI assistance bar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
    </div>
</div>

<script>
    import { copyAndOpenAI } from './AIAssistClient';

    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('ai-quick-assist-bar');
        const dismissBtn = document.getElementById('dismiss-ai-bar');
        const actionBtns = document.querySelectorAll('.ai-quick-action');

        if (!bar) return;

        // Check session storage
        if (!sessionStorage.getItem('aiAssistBarDismissed')) {
            bar.classList.remove('hidden');
        }

        if (dismissBtn) {
            dismissBtn.addEventListener('click', () => {
                bar.classList.add('hidden');
                sessionStorage.setItem('aiAssistBarDismissed', 'true');
            });
        }

        actionBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const actionId = target.dataset.action || 'summarize_page';
                const url = target.dataset.url || 'https://chatgpt.com/';
                const name = target.dataset.name || 'ChatGPT';

                await copyAndOpenAI(actionId, url, name);
            });
        });
    });
</script>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
