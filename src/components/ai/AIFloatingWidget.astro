---
import { aiAssistants } from '../../data/aiAssistants';
import AIAssistantButton from './AIAssistantButton.astro';

const actions = [
    { id: 'summarize_page', label: 'Summarize this page' },
    { id: 'explain_service', label: 'Explain this service in simple words' },
    { id: 'help_me_choose', label: 'Help me decide if this is right for my business' },
    { id: 'create_action_plan', label: 'Create an action plan' },
    { id: 'compare_options', label: 'Compare options' },
    { id: 'ask_questions', label: 'Questions to ask before booking' }
];
---

<div id="ai-floating-widget" class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 flex flex-col items-end">
    <!-- Closed State Button -->
    <button id="ai-widget-toggle" class="bg-brand-primary hover:bg-brand-navy text-white rounded-full shadow-lg flex items-center justify-center p-3 sm:px-4 transition-all duration-300 focus-ring group" aria-label="Open AI Assistant" aria-expanded="false">
        <svg class="w-6 h-6 sm:mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
        <span class="hidden sm:block font-medium">Ask AI</span>
    </button>

    <!-- Opened State Panel -->
    <div id="ai-widget-panel" class="hidden absolute bottom-full mb-4 right-0 w-[calc(100vw-2rem)] sm:w-80 bg-white rounded-xl shadow-2xl border border-slate-100 overflow-hidden transition-all duration-300 origin-bottom-right transform scale-95 opacity-0 pointer-events-none" role="dialog" aria-label="AI Assistant Panel">
        <!-- Header -->
        <div class="bg-brand-softBg border-b border-brand-border/50 p-4 flex justify-between items-center">
            <h3 class="font-bold text-brand-primary text-sm">Use AI to understand this page</h3>
            <div class="flex items-center space-x-1">
                <button id="ai-widget-minimize" class="text-slate-400 hover:text-brand-primary p-1 focus-ring rounded-md" aria-label="Minimize widget">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <button id="ai-widget-close" class="text-slate-400 hover:text-brand-primary p-1 focus-ring rounded-md" aria-label="Close widget for this session">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>

        <div class="p-4 max-h-[60vh] overflow-y-auto custom-scrollbar">
            <p class="text-xs text-slate-600 mb-4">Copy a ready-made prompt and open your preferred AI assistant.</p>

            <!-- Step 1: Action -->
            <div class="mb-5">
                <label class="block text-xs font-bold text-slate-800 mb-2 uppercase tracking-wide">1. Select Action</label>
                <select id="ai-widget-action" class="w-full text-sm border border-slate-200 rounded-md p-2 bg-slate-50 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary outline-none text-slate-700 cursor-pointer">
                    {actions.map(action => (
                        <option value={action.id}>{action.label}</option>
                    ))}
                </select>
            </div>

            <!-- Step 2: Platform -->
            <div>
                <label class="block text-xs font-bold text-slate-800 mb-2 uppercase tracking-wide flex justify-between items-center">
                    <span>2. Choose AI</span>
                    <button id="ai-widget-copy-only" class="text-brand-accent hover:text-brand-primary underline text-[10px] font-normal focus:outline-none">Copy prompt only</button>
                </label>
                <div class="grid grid-cols-2 gap-2">
                    {aiAssistants.map(assistant => (
                        <AIAssistantButton assistant={assistant} variant="button" class="widget-platform-btn" />
                    ))}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    import { generatePrompt, copyAndOpenAI } from './AIAssistClient';

    document.addEventListener('DOMContentLoaded', () => {
        const widget = document.getElementById('ai-floating-widget');
        const toggleBtn = document.getElementById('ai-widget-toggle');
        const panel = document.getElementById('ai-widget-panel');
        const minimizeBtn = document.getElementById('ai-widget-minimize');
        const closeBtn = document.getElementById('ai-widget-close');
        const actionSelect = document.getElementById('ai-widget-action') as HTMLSelectElement;
        const platformBtns = document.querySelectorAll('.widget-platform-btn');
        const copyOnlyBtn = document.getElementById('ai-widget-copy-only');

        if (!widget || !toggleBtn || !panel) return;

        // Check if hidden for session
        if (sessionStorage.getItem('aiWidgetHidden')) {
            widget.classList.add('hidden');
            return;
        }

        const openPanel = () => {
            panel.classList.remove('hidden');
            toggleBtn.setAttribute('aria-expanded', 'true');
            // small delay for transition
            requestAnimationFrame(() => {
                panel.classList.remove('scale-95', 'opacity-0', 'pointer-events-none');
            });
        };

        const closePanel = () => {
            panel.classList.add('scale-95', 'opacity-0', 'pointer-events-none');
            toggleBtn.setAttribute('aria-expanded', 'false');
            setTimeout(() => {
                panel.classList.add('hidden');
            }, 300);
        };

        toggleBtn.addEventListener('click', () => {
            const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
            if (isExpanded) {
                closePanel();
            } else {
                openPanel();
            }
        });

        minimizeBtn?.addEventListener('click', closePanel);

        closeBtn?.addEventListener('click', () => {
            closePanel();
            setTimeout(() => {
                widget.classList.add('hidden');
                sessionStorage.setItem('aiWidgetHidden', 'true');
            }, 300);
        });

        // Platform buttons click
        platformBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const actionId = actionSelect.value;
                const url = target.dataset.aiUrl || '';
                const name = target.dataset.aiName || '';

                await copyAndOpenAI(actionId, url, name);
                closePanel();
            });
        });

        // Copy only click
        copyOnlyBtn?.addEventListener('click', async () => {
            const actionId = actionSelect.value;
            const prompt = generatePrompt(actionId);

            try {
                if (navigator.clipboard && window.isSecureContext) {
                    await navigator.clipboard.writeText(prompt);
                    const toastEvent = new CustomEvent('show-ai-toast', {
                        detail: { title: "Success", message: "Prompt copied to clipboard. You can paste it anywhere." }
                    });
                    window.dispatchEvent(toastEvent);
                } else {
                    const modalEvent = new CustomEvent('show-ai-modal', {
                        detail: { prompt, platformUrl: '' }
                    });
                    window.dispatchEvent(modalEvent);
                }
            } catch (err) {
                 const modalEvent = new CustomEvent('show-ai-modal', {
                    detail: { prompt, platformUrl: '' }
                });
                window.dispatchEvent(modalEvent);
            }
            closePanel();
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
            if (!widget.contains(e.target as Node) && toggleBtn.getAttribute('aria-expanded') === 'true') {
                closePanel();
            }
        });

        // Close on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && toggleBtn.getAttribute('aria-expanded') === 'true') {
                closePanel();
                toggleBtn.focus();
            }
        });
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 20px;
    }
</style>
