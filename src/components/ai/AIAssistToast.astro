---
---

<div id="ai-toast-container" class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-[100] flex flex-col gap-2 pointer-events-none">
    <!-- Toasts will be injected here -->
</div>

<div id="ai-fallback-modal" class="fixed inset-0 z-[110] bg-brand-navy/80 backdrop-blur-sm hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-xl shadow-2xl max-w-lg w-full p-6 relative transform scale-95 transition-transform duration-300" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <button id="ai-modal-close" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 focus-ring rounded-full p-1" aria-label="Close modal">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        <h3 id="modal-title" class="text-xl font-bold text-brand-primary mb-2">Copy your prompt</h3>
        <p class="text-sm text-slate-600 mb-4">We couldn't automatically copy the prompt. Please copy it below and continue to your AI assistant.</p>
        <textarea id="ai-modal-textarea" class="w-full h-48 p-3 border border-slate-200 rounded-md text-sm text-slate-700 bg-slate-50 focus:border-brand-accent/30 focus:ring-1 focus:ring-brand-accent outline-none resize-none mb-4" readonly></textarea>
        <div class="flex flex-col sm:flex-row gap-3">
            <button id="ai-modal-copy-btn" class="flex-1 bg-brand-primary text-white py-2 rounded-md font-medium hover:bg-brand-navy transition-colors focus-ring">Copy Manually</button>
            <button id="ai-modal-open-btn" class="flex-1 bg-brand-accent text-white py-2 rounded-md font-medium hover:bg-brand-primary transition-colors focus-ring">Open AI Assistant</button>
        </div>
        <p id="ai-modal-copy-status" class="text-xs text-brand-accent font-medium mt-2 text-center h-4 opacity-0 transition-opacity">Copied!</p>
    </div>
</div>

<script>
    let toastTimeout: any;
    let currentPlatformUrl = "";

    window.addEventListener('show-ai-toast', (e: any) => {
        const { title, message } = e.detail;
        const container = document.getElementById('ai-toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = 'bg-white border-l-4 border-brand-accent/30 shadow-lg rounded-md p-4 max-w-sm w-full transform translate-y-full opacity-0 transition-all duration-300 pointer-events-auto flex items-start gap-3';
        toast.innerHTML = `
            <div class="text-brand-accent flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
                <h4 class="text-sm font-bold text-slate-800">${title}</h4>
                <p class="text-xs text-slate-600 mt-1">${message}</p>
            </div>
            <button class="ml-auto text-slate-400 hover:text-slate-600 focus:outline-none" onclick="this.parentElement.remove()">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        `;

        container.appendChild(toast);

        // Trigger animation
        requestAnimationFrame(() => {
            toast.classList.remove('translate-y-full', 'opacity-0');
        });

        clearTimeout(toastTimeout);
        toastTimeout = setTimeout(() => {
            toast.classList.add('opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    });

    window.addEventListener('show-ai-modal', (e: any) => {
        const { prompt, platformUrl } = e.detail;
        const modal = document.getElementById('ai-fallback-modal');
        const textarea = document.getElementById('ai-modal-textarea') as HTMLTextAreaElement;

        if (modal && textarea) {
            currentPlatformUrl = platformUrl;
            textarea.value = prompt;
            modal.classList.remove('hidden');
            // small delay for transition
            requestAnimationFrame(() => {
                modal.classList.remove('opacity-0');
                modal.querySelector('div')?.classList.remove('scale-95');
            });
            document.body.style.overflow = 'hidden';
        }
    });

    // Setup modal listeners once
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('ai-fallback-modal');
        const closeBtn = document.getElementById('ai-modal-close');
        const copyBtn = document.getElementById('ai-modal-copy-btn');
        const openBtn = document.getElementById('ai-modal-open-btn');
        const textarea = document.getElementById('ai-modal-textarea') as HTMLTextAreaElement;
        const status = document.getElementById('ai-modal-copy-status');

        const closeModal = () => {
            if (modal) {
                modal.classList.add('opacity-0');
                modal.querySelector('div')?.classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    document.body.style.overflow = '';
                }, 300);
            }
        };

        if (closeBtn) closeBtn.addEventListener('click', closeModal);

        if (modal) {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                    closeModal();
                }
            });
        }

        if (copyBtn && textarea && status) {
            copyBtn.addEventListener('click', () => {
                textarea.select();
                try {
                    document.execCommand('copy');
                    status.classList.remove('opacity-0');
                    setTimeout(() => status.classList.add('opacity-0'), 2000);
                } catch (err) {
                    console.error('Fallback copy failed', err);
                }
            });
        }

        if (openBtn) {
            openBtn.addEventListener('click', () => {
                if (currentPlatformUrl) {
                    window.open(currentPlatformUrl, "_blank", "noopener,noreferrer");
                    closeModal();
                }
            });
        }
    });
</script>
