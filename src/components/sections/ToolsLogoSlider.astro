---
// src/components/sections/ToolsLogoSlider.astro
import { tools } from '../../data/tools';
---
<section class="py-16 bg-white overflow-hidden border-b border-brand-border">
  <div class="container mx-auto px-4 mb-10 text-center">
    <h2 class="text-3xl font-bold text-brand-navy mb-4">Most Used Tools</h2>
    <p class="text-brand-textMuted max-w-2xl mx-auto">
      We work across popular course, LMS, and learning technology platforms to help teams organize, deliver, and improve online learning.
    </p>
  </div>

  <!-- Accessible Slider Container -->
  <div class="relative w-full overflow-hidden" aria-label="Learning platforms and tools supported by TheEduAssist" tabindex="0">
    <div class="logo-track logo-marquee gap-8 px-4 flex items-center">
      <!-- We double the list to create a seamless loop, or just use CSS grid on desktop -->
      {tools.map(tool => (
        <div class="flex-shrink-0 bg-brand-softBg border border-brand-border px-6 py-3 rounded-lg shadow-sm hover-lift">
          <span class="text-lg font-semibold text-brand-navy">{tool.name}</span>
        </div>
      ))}
      <!-- Duplicate for marquee effect -->
      {tools.map(tool => (
        <div class="flex-shrink-0 bg-brand-softBg border border-brand-border px-6 py-3 rounded-lg shadow-sm hover-lift" aria-hidden="true">
          <span class="text-lg font-semibold text-brand-navy">{tool.name}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="container mx-auto px-4 mt-8 text-center">
    <p class="text-xs text-brand-textMuted">
      Platform support does not imply official partnership unless stated.
    </p>
  </div>
</section>
