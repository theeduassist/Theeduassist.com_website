---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';
import { services } from '../../data/services';
---
<section class="py-20 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-brand-primary">Tailored eLearning solutions for businesses, educators, and training teams</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.coreServices.map(service => (
        <Card className="flex flex-col h-full hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold mb-3 text-slate-900">{service.title}</h3>
          <p class="text-slate-600 mb-6 flex-grow">{service.description}</p>
          <div class="mt-auto">
            {service.link ? (
              <a href={service.link} class="text-blue-600 font-medium hover:underline inline-flex items-center">
                Learn more
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            ) : (
              <a href="/services/" class="text-slate-500 font-medium hover:text-blue-600 transition-colors text-sm">
                View service overview &rarr;
              </a>
            )}
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>
