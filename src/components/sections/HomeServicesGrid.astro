---
// src/components/sections/HomeServicesGrid.astro
import { homeServices } from '../../data/homeServices';
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">
        Our Key Services
      </h2>
      <p class="text-lg text-brand-textMuted">
        We help you plan, build, and launch tailored learning experiences across platforms.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {homeServices.map((service, index) => (
        <div class="bg-white rounded-xl p-6 shadow-sm border border-brand-border hover-lift flex flex-col h-full reveal-card" style={`animation-delay: ${index * 50}ms;`}>
          <div class="bg-brand-softGreen text-brand-accent w-12 h-12 rounded-lg flex items-center justify-center mb-5">
            <Fragment set:html={service.icon} />
          </div>

          <h3 class="text-xl font-bold text-brand-navy mb-3">{service.title}</h3>

          <p class="text-brand-textMain mb-4 flex-grow">
            {service.description}
          </p>

          <div class="bg-brand-softBg rounded p-3 mb-5 border border-brand-border/50">
            <span class="text-xs font-semibold uppercase tracking-wider text-brand-textMuted block mb-1">Best for</span>
            <span class="text-sm text-brand-navy font-medium">{service.bestFor}</span>
          </div>

          <a href={service.ctaLink} class="inline-flex items-center text-brand-primary font-semibold hover:text-brand-accent transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 rounded group mt-auto">
            {service.ctaLabel}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
