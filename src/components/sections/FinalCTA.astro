---
import Button from '../ui/Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaLink?: string;
}

const {
  title = "Build your online academy and start your learning journey with confidence.",
  subtitle = "Let's discuss how we can structure, build, or migrate your learning content.",
  ctaLabel = "Book Free Audit",
  ctaLink = "/book-free-audit/"
} = Astro.props;
---
<section class="py-24 bg-brand-primary text-white text-center relative overflow-hidden">
  <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white to-transparent"></div>
  <div class="max-w-4xl mx-auto px-4 relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-6">{title}</h2>
    <p class="text-xl text-blue-100 mb-10 max-w-2xl mx-auto">{subtitle}</p>
    <Button href={ctaLink} variant="white" size="lg">
      {ctaLabel}
    </Button>
  </div>
</section>
