---
// src/components/sections/HomeBlogPreview.astro
const blogPosts = [
  {
    title: "How to Convert Legacy Training Content to Modern eLearning",
    category: "eLearning Strategy",
    date: "Pending Migration",
    url: "/blog/"
  },
  {
    title: "How to Build a Corporate eLearning Program on a Budget: A Complete 2026 Guide",
    category: "Corporate Training",
    date: "Pending Migration",
    url: "/blog/"
  },
  {
    title: "Kajabi Major Updates 2026: AI Cofounder, Expert Agents, Amplify & More",
    category: "Platform News",
    date: "Pending Migration",
    url: "/blog/"
  }
];
---
<section class="py-24 bg-white border-b border-brand-border/50">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">
          Course News & Blogs
        </h2>
        <p class="text-lg text-brand-textMuted">
          Practical guides, platform updates, and strategies for better online learning.
        </p>
      </div>
      <div>
        <a href="/blog/" class="inline-flex items-center text-brand-primary font-semibold hover:text-brand-accent transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 rounded group">
          View all articles
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {blogPosts.map((post, index) => (
        <a href={post.url} class={`bg-brand-softBg rounded-2xl p-6 shadow-sm border border-brand-border hover-lift flex flex-col h-full reveal-card group`} style={`animation-delay: ${index * 100}ms;`}>
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-semibold bg-white border border-brand-border px-2 py-1 rounded text-brand-navy">
              {post.category}
            </span>
            <span class="text-xs text-brand-textMuted bg-brand-softBlue px-2 py-1 rounded border border-brand-primary/10">
              {post.date}
            </span>
          </div>

          <h3 class="text-lg font-bold text-brand-navy mb-4 group-hover:text-brand-primary transition-colors leading-tight">
            {post.title}
          </h3>

          <div class="mt-auto flex items-center text-sm font-semibold text-brand-primary pt-4 border-t border-brand-border/50">
            Read article
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
