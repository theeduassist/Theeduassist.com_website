---
import Button from '../ui/Button.astro';

interface Props {
  title: string;
  subtitle: string;
  heroBadge?: string;
  primaryCtaLabel: string;
  primaryCtaLink: string;
  secondaryCtaLabel?: string;
  secondaryCtaLink?: string;
  tertiaryCtaLabel?: string;
  tertiaryCtaLink?: string;
  trustText?: string;
  showDashboardVisual?: boolean;
}

const {
  title,
  subtitle,
  heroBadge,
  primaryCtaLabel,
  primaryCtaLink,
  secondaryCtaLabel,
  secondaryCtaLink,
  tertiaryCtaLabel,
  tertiaryCtaLink,
  trustText,
  showDashboardVisual = false
} = Astro.props;
---
<section class="py-20 bg-brand-softBg text-center px-4 md:py-28 animate-fade-up">
  <div class="max-w-4xl mx-auto">
    {heroBadge && (
      <div class="inline-block px-4 py-1.5 rounded-full bg-brand-softGreen text-brand-accent font-semibold text-sm mb-6 shadow-sm border border-brand-accent/20">
        {heroBadge}
      </div>
    )}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy mb-6 leading-tight">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-brand-textMuted max-w-3xl mx-auto mb-8 leading-relaxed">
      {subtitle}
    </p>
    {trustText && (
      <p class="text-sm font-medium text-brand-navy max-w-2xl mx-auto mb-10 pb-4 border-b border-brand-border/50">
        {trustText}
      </p>
    )}
    <div class={`flex flex-col sm:flex-row justify-center items-center gap-4 ${showDashboardVisual ? 'mb-16' : ''}`}>
      <Button href={primaryCtaLink} variant="primary" size="lg">{primaryCtaLabel}</Button>
      {secondaryCtaLabel && secondaryCtaLink && (
        <Button href={secondaryCtaLink} variant="outline" size="lg">{secondaryCtaLabel}</Button>
      )}
      {tertiaryCtaLabel && tertiaryCtaLink && (
        <Button href={tertiaryCtaLink} variant="outline" size="lg">{tertiaryCtaLabel}</Button>
      )}
    </div>

    {showDashboardVisual && (
    <!-- Dashboard-Style Visual Panel -->
    <div class="bg-gradient-to-br from-brand-softBlue to-brand-softBg p-8 rounded-2xl shadow-sm border border-brand-border/50 max-w-4xl mx-auto relative overflow-hidden">
      <!-- Decorative background glow -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-brand-accent/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-brand-softGreen/50 rounded-full blur-3xl"></div>

      <div class="relative z-10 grid grid-cols-2 md:grid-cols-3 gap-4 text-sm font-medium text-brand-navy">
        <div class="bg-white py-4 px-4 rounded-xl shadow-sm border border-brand-border flex flex-col items-center justify-center gap-3 hover-lift transition-all hover:border-brand-accent/30 group">
            <div class="bg-brand-softGreen/50 p-2 rounded-lg group-hover:bg-brand-softGreen transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            Course Strategy
        </div>
        <div class="bg-white py-4 px-4 rounded-xl shadow-sm border border-brand-border flex flex-col items-center justify-center gap-3 hover-lift transition-all hover:border-brand-accent/30 group">
            <div class="bg-brand-softGreen/50 p-2 rounded-lg group-hover:bg-brand-softGreen transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            LMS Setup
        </div>
        <div class="bg-white py-4 px-4 rounded-xl shadow-sm border border-brand-border flex flex-col items-center justify-center gap-3 hover-lift transition-all hover:border-brand-accent/30 group">
            <div class="bg-brand-softGreen/50 p-2 rounded-lg group-hover:bg-brand-softGreen transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
            </div>
            Kajabi Build
        </div>
        <div class="bg-white py-4 px-4 rounded-xl shadow-sm border border-brand-border flex flex-col items-center justify-center gap-3 hover-lift transition-all hover:border-brand-accent/30 group">
            <div class="bg-brand-softGreen/50 p-2 rounded-lg group-hover:bg-brand-softGreen transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
            </div>
            Content Flow
        </div>
        <div class="bg-white py-4 px-4 rounded-xl shadow-sm border border-brand-border flex flex-col items-center justify-center gap-3 hover-lift transition-all hover:border-brand-accent/30 group">
            <div class="bg-brand-softGreen/50 p-2 rounded-lg group-hover:bg-brand-softGreen transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
            </div>
            AI Learning Support
        </div>
        <div class="bg-white py-4 px-4 rounded-xl shadow-sm border border-brand-border flex flex-col items-center justify-center gap-3 hover-lift transition-all hover:border-brand-accent/30 group">
            <div class="bg-brand-softGreen/50 p-2 rounded-lg group-hover:bg-brand-softGreen transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
            </div>
            Launch Checklist
        </div>
      </div>
    </div>
    )}
  </div>
</section>
