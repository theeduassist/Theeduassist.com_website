---
import Button from '../ui/Button.astro';

interface Props {
  title: string;
  subtitle: string;
  heroBadge?: string;
  primaryCtaLabel: string;
  primaryCtaLink: string;
  secondaryCtaLabel?: string;
  secondaryCtaLink?: string;
  tertiaryCtaLabel?: string;
  tertiaryCtaLink?: string;
  trustText?: string;
}

const {
  title,
  subtitle,
  heroBadge,
  primaryCtaLabel,
  primaryCtaLink,
  secondaryCtaLabel,
  secondaryCtaLink,
  tertiaryCtaLabel,
  tertiaryCtaLink,
  trustText
} = Astro.props;
---
<section class="py-20 bg-brand-softBg text-center px-4 md:py-28 animate-fade-up">
  <div class="max-w-4xl mx-auto">
    {heroBadge && (
      <div class="inline-block px-4 py-1.5 rounded-full bg-brand-softGreen text-brand-accent font-semibold text-sm mb-6 shadow-sm border border-brand-accent/20">
        {heroBadge}
      </div>
    )}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy mb-6 leading-tight">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-brand-textMuted max-w-3xl mx-auto mb-10 leading-relaxed">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-16">
      <Button href={primaryCtaLink} variant="primary" size="lg">{primaryCtaLabel}</Button>
      {secondaryCtaLabel && secondaryCtaLink && (
        <Button href={secondaryCtaLink} variant="outline" size="lg">{secondaryCtaLabel}</Button>
      )}
      {tertiaryCtaLabel && tertiaryCtaLink && (
        <Button href={tertiaryCtaLink} variant="outline" size="lg">{tertiaryCtaLabel}</Button>
      )}
    </div>

    <!-- Visual Cards / Feature Pills -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-3xl mx-auto text-sm font-medium text-brand-navy">
        <div class="bg-white py-3 px-4 rounded-lg shadow-sm border border-brand-border flex items-center justify-center gap-2 hover-lift">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Course Strategy
        </div>
        <div class="bg-white py-3 px-4 rounded-lg shadow-sm border border-brand-border flex items-center justify-center gap-2 hover-lift">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            LMS Setup
        </div>
        <div class="bg-white py-3 px-4 rounded-lg shadow-sm border border-brand-border flex items-center justify-center gap-2 hover-lift">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Kajabi Build
        </div>
        <div class="bg-white py-3 px-4 rounded-lg shadow-sm border border-brand-border flex items-center justify-center gap-2 hover-lift">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Content Flow
        </div>
        <div class="bg-white py-3 px-4 rounded-lg shadow-sm border border-brand-border flex items-center justify-center gap-2 hover-lift">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            AI Learning Support
        </div>
        <div class="bg-white py-3 px-4 rounded-lg shadow-sm border border-brand-border flex items-center justify-center gap-2 hover-lift">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Launch Checklist
        </div>
    </div>
  </div>
</section>
