---
// src/components/sections/HomeHero.astro
---
<section class="relative bg-brand-primary text-white overflow-hidden py-20 lg:py-32">
  <!-- Decorative Background Orbs -->
  <div class="gradient-orb bg-brand-accent w-96 h-96 top-0 left-0 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="gradient-orb bg-brand-softBlue w-[500px] h-[500px] bottom-0 right-0 translate-x-1/3 translate-y-1/3 opacity-20"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Text Content -->
      <div class="animate-slide-in">
        <span class="inline-block px-3 py-1 bg-brand-accent/20 text-brand-accent rounded-full text-sm font-semibold tracking-wide mb-6">
          E-Learning Design Agency
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Custom eLearning, Kajabi, and LMS Solutions Built to Launch Faster
        </h1>
        <p class="text-lg text-brand-softBlue mb-4 max-w-xl">
          TheEduAssist helps coaches, course creators, educators, and training teams turn content into structured online learning experiences, from Kajabi setup and LMS migration to AI-supported course design and launch support.
        </p>
        <p class="text-sm text-brand-softBlue/80 mb-8 max-w-xl">
          Strategy, course structure, platform setup, content flow, automation, testing, and launch support in one practical process.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/book-free-audit/" class="inline-block bg-brand-accent text-white px-8 py-4 rounded-lg font-semibold hover:bg-brand-accent/90 transition-colors focus:ring-2 focus:ring-brand-accent focus:ring-offset-2 focus:ring-offset-brand-primary">
            Book Free Audit
          </a>
          <a href="https://calendly.com/eduassist-talk/30min?month" target="_blank" rel="noopener noreferrer" aria-label="Schedule a 30-Minute Discussion on Calendly" class="inline-block bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-colors focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-brand-primary">
            Schedule a 30-Minute Discussion
          </a>
          <a href="/kajabi-services/" class="inline-block border border-white/30 hover:border-white text-white px-8 py-4 rounded-lg font-semibold transition-colors focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-brand-primary mt-4 sm:mt-0">
            Explore Kajabi Services
          </a>
        </div>
      </div>

      <!-- Dashboard Visual Tile -->
      <div class="animate-fade-up lg:ml-auto w-full max-w-md">
        <div class="bg-brand-softBg rounded-2xl p-6 shadow-2xl border border-brand-border/20 text-brand-textMain relative">
          <!-- Window controls decorative -->
          <div class="flex gap-2 mb-6">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
          </div>

          <div class="space-y-4">
            <!-- Visual Cards -->
            <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center gap-4 hover-lift">
              <div class="bg-brand-softBlue p-2 rounded-lg text-brand-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg>
              </div>
              <span class="font-semibold text-brand-navy">Course Strategy</span>
            </div>

            <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center gap-4 hover-lift">
              <div class="bg-brand-softBlue p-2 rounded-lg text-brand-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
              </div>
              <span class="font-semibold text-brand-navy">Kajabi Setup</span>
            </div>

            <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center gap-4 hover-lift">
              <div class="bg-brand-softBlue p-2 rounded-lg text-brand-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
              </div>
              <span class="font-semibold text-brand-navy">LMS Migration</span>
            </div>

            <div class="bg-white p-4 rounded-xl shadow-sm border border-brand-border flex items-center gap-4 hover-lift">
              <div class="bg-brand-softBlue p-2 rounded-lg text-brand-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>
              </div>
              <span class="font-semibold text-brand-navy">AI Learning Support</span>
            </div>

            <div class="bg-brand-accent/10 p-4 rounded-xl shadow-sm border border-brand-accent/30 flex items-center gap-4 hover-lift">
              <div class="bg-brand-accent text-white p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="font-bold text-brand-navy">Launch Checklist</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
