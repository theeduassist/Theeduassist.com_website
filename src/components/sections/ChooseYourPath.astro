      <a href="/services/" class="brand-card p-6 flex flex-col items-center text-center hover-lift group focus-ring outline-none bg-white">
        <div class="w-12 h-12 bg-brand-softBlue rounded-full flex items-center justify-center mb-4 text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </div>
        <h3 class="font-bold text-brand-textMain mb-2">I need training for my team</h3>
        <span class="text-brand-accent mt-auto text-sm font-bold flex items-center group-hover:translate-x-1 transition-transform">
          Explore Services <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
