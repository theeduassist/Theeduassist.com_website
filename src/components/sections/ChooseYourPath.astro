<section class="py-24 bg-brand-softGreen">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-primary mb-4">Choose the support that matches where you are now</h2>
      <p class="text-brand-textMuted text-lg max-w-2xl mx-auto">We meet you where you are and provide practical, scalable solutions.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">

      <a href="/kajabi-services/" class="brand-card p-6 flex flex-col items-center text-center hover-lift group focus-ring outline-none bg-white">
        <div class="w-12 h-12 bg-brand-softBlue rounded-full flex items-center justify-center mb-4 text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="font-bold text-brand-textMain mb-2">I want to launch a Kajabi course</h3>
