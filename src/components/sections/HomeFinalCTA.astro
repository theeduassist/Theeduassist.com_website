---
// src/components/sections/HomeFinalCTA.astro
---
<section class="py-24 bg-brand-softBg">
  <div class="container mx-auto px-4">
    <div class="bg-white rounded-3xl p-8 md:p-16 shadow-lg border border-brand-border max-w-4xl mx-auto text-center reveal-card relative overflow-hidden">

      <!-- Decorative Elements -->
      <div class="absolute top-0 right-0 w-32 h-32 bg-brand-softBlue rounded-bl-full z-0 opacity-50"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-brand-softGreen rounded-tr-full z-0 opacity-50"></div>

      <div class="relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold text-brand-navy mb-6">
          Ready to make your course, LMS, or Kajabi setup easier to launch?
        </h2>

        <p class="text-lg text-brand-textMuted mb-10 max-w-2xl mx-auto">
          Share your current setup, course idea, or platform challenge. We’ll help you identify the next practical step.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="/book-free-audit/" class="inline-block bg-brand-accent text-white px-8 py-4 rounded-lg font-semibold hover:bg-brand-accent/90 transition-colors focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2">
            Book Free Audit
          </a>
          <a href="https://calendly.com/eduassist-talk/30min?month" target="_blank" rel="noopener noreferrer" aria-label="Schedule a 30-Minute Discussion on Calendly" class="inline-block bg-white text-brand-primary border border-brand-primary px-8 py-4 rounded-lg font-semibold hover:bg-brand-softBg transition-colors focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
            Schedule a 30-Minute Discussion
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
