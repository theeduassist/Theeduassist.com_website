---
// src/components/sections/OnlineAcademyCTA.astro
---
<section class="py-20 bg-brand-primary text-white relative overflow-hidden">
  <div class="gradient-orb bg-brand-accent w-64 h-64 top-1/2 left-0 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="gradient-orb bg-brand-softBlue w-96 h-96 bottom-0 right-0 translate-x-1/3 translate-y-1/3 opacity-20"></div>

  <div class="container mx-auto px-4 relative z-10 text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Build your online academy and start your learning journey with confidence.
      </h2>
      <p class="text-lg text-brand-softBlue mb-10">
        From content organization and platform setup to launch support and learner experience, we help you create a system your team can manage confidently.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="/book-free-audit/" class="inline-block bg-brand-accent text-white px-8 py-4 rounded-lg font-semibold hover:bg-brand-accent/90 transition-colors focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand-primary">
          Book Free Audit
        </a>
        <a href="https://calendly.com/eduassist-talk/30min?month" target="_blank" rel="noopener noreferrer" aria-label="Schedule a 30-Minute Discussion on Calendly" class="inline-block bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-colors focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand-primary">
          Schedule a 30-Minute Discussion
        </a>
      </div>
    </div>
  </div>
</section>
