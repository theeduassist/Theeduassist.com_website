---
// src/components/sections/HomeCaseStudyProof.astro
import { homeCaseStudies } from '../../data/homeCaseStudies';
---
<section class="py-24 bg-brand-softBg">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">
          Recent Projects
        </h2>
        <p class="text-lg text-brand-textMuted">
          Examples of structured eLearning, platform implementations, and structured course designs.
        </p>
      </div>
      <div>
        <a href="/case-studies/" class="inline-flex items-center bg-white border border-brand-border text-brand-primary px-6 py-3 rounded-lg font-semibold hover:bg-brand-softBlue hover:border-brand-primary/30 transition-colors focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 shadow-sm group">
          View Case Studies
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {homeCaseStudies.map((study, index) => (
        <a href="/case-studies/" class={`bg-white rounded-2xl p-8 shadow-sm border border-brand-border hover-lift flex flex-col h-full reveal-card group`} style={`animation-delay: ${index * 150}ms;`}>
          <span class="text-xs font-semibold uppercase tracking-wider text-brand-accent mb-4 block">
            {study.category}
          </span>
          <h3 class="text-xl font-bold text-brand-navy mb-4 group-hover:text-brand-primary transition-colors">
            {study.title}
          </h3>
          <p class="text-brand-textMain mb-8 flex-grow">
            {study.summary}
          </p>
          <div class="mt-auto flex items-center text-sm font-semibold text-brand-primary">
            Read summary
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
