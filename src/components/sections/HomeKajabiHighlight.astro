---
// src/components/sections/HomeKajabiHighlight.astro
---
<section class="py-20 bg-brand-softBlue/30 border-y border-brand-border/50">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <div class="reveal-card">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-white border border-brand-border rounded-full text-sm font-semibold tracking-wide text-brand-navy mb-6 shadow-sm">
          <span class="text-brand-primary">Kajabi</span> System Build
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
          Build, Launch, and Scale Your Online Course Business on Kajabi
        </h2>

        <p class="text-lg text-brand-textMain mb-6">
          From course setup and landing pages to checkout, email automation, communities, and student experience, TheEduAssist helps you turn Kajabi into a complete online learning and sales system.
        </p>

        <p class="text-xs text-brand-textMuted mb-8">
          Kajabi is a third-party platform. Platform support does not imply official partnership unless stated.
        </p>

        <!-- Features -->
        <div class="flex flex-wrap gap-2 mb-8">
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Course Setup</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Landing Pages</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Checkout</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Email Automations</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Communities</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Student Experience</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Creator Studio Support</span>
          <span class="bg-white border border-brand-border px-3 py-1 rounded text-sm text-brand-navy shadow-sm">Migration & Cleanup</span>
        </div>

        <div class="flex flex-wrap gap-4">
          <a href="/kajabi-services/" class="inline-block bg-brand-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-navy transition-colors focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
            Explore Kajabi Services
          </a>
          <a href="/book-free-audit/" class="inline-block bg-white text-brand-primary border border-brand-primary px-6 py-3 rounded-lg font-semibold hover:bg-brand-softBg transition-colors focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
            Book a Kajabi Audit
          </a>
        </div>
      </div>

      <!-- Infographic flow -->
      <div class="lg:ml-auto w-full reveal-card" style="animation-delay: 200ms;">
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-brand-border relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-brand-softGreen rounded-bl-full z-0 opacity-50"></div>

          <h3 class="font-bold text-brand-navy mb-6 relative z-10 text-center">The Connected System</h3>

          <div class="space-y-4 relative z-10">
            <div class="flex items-center gap-4 bg-brand-softBg p-3 rounded-lg border border-brand-border hover-lift">
              <div class="w-8 h-8 rounded bg-brand-softBlue text-brand-primary flex items-center justify-center shrink-0">1</div>
              <span class="font-medium text-brand-navy">Website & Lead Capture</span>
            </div>

            <div class="flex justify-center text-brand-textMuted">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
            </div>

            <div class="flex items-center gap-4 bg-brand-softBg p-3 rounded-lg border border-brand-border hover-lift">
              <div class="w-8 h-8 rounded bg-brand-softBlue text-brand-primary flex items-center justify-center shrink-0">2</div>
              <span class="font-medium text-brand-navy">Email Automation & Offer</span>
            </div>

            <div class="flex justify-center text-brand-textMuted">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7-7-7-7"/></svg>
            </div>

            <div class="flex items-center gap-4 bg-brand-softBg p-3 rounded-lg border border-brand-border hover-lift">
              <div class="w-8 h-8 rounded bg-brand-softBlue text-brand-primary flex items-center justify-center shrink-0">3</div>
              <span class="font-medium text-brand-navy">Checkout & Course Access</span>
            </div>

            <div class="flex justify-center text-brand-textMuted">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
            </div>

            <div class="flex items-center gap-4 bg-brand-accent/10 p-3 rounded-lg border border-brand-accent/30 hover-lift">
              <div class="w-8 h-8 rounded bg-brand-accent text-white flex items-center justify-center shrink-0">4</div>
              <span class="font-bold text-brand-navy">Learning & Community</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
