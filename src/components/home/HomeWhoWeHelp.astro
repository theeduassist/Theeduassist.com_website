---
const audiences = [
  "Coaches",
  "Course creators",
  "Consultants",
  "Online academies",
  "Real estate educators",
  "Fitness and wellness experts",
  "Training companies",
  "Membership businesses",
  "Corporate educators",
  "Service providers selling training"
];
---
<section class="py-20 md:py-28 bg-white border-y border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8 items-center">
      <div class="lg:col-span-1">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-primary mb-6">Built for knowledge-based businesses</h2>
        <p class="text-lg text-brand-textMuted leading-relaxed">
          TheEduAssist works best with experts and teams who need a clearer way to present, sell, and deliver learning online.
        </p>
      </div>
      <div class="lg:col-span-2 grid grid-cols-2 md:grid-cols-3 gap-4">
        {audiences.map((audience) => (
          <div class="bg-brand-softBg border border-brand-border rounded-xl p-4 flex items-center justify-center text-center hover-lift transition-transform">
            <span class="font-semibold text-brand-primary text-sm md:text-base">{audience}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
