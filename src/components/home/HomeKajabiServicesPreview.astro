---
const services = [
  {
    title: "Kajabi Website Design",
    route: "/kajabi-website-design/",
    copy: "Custom Kajabi website pages designed to present your expertise clearly and professionally.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>`
  },
  {
    title: "Kajabi Landing Page Design",
    route: "/kajabi-landing-page-design/",
    copy: "Focused sales and opt-in pages for course launches, lead magnets, webinars, and offers.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>`
  },
  {
    title: "Kajabi Course Setup",
    route: "/kajabi-course-setup/",
    copy: "Course products, modules, lessons, downloads, thumbnails, and student navigation setup.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>`
  },
  {
    title: "Kajabi Funnel Setup",
    route: "/kajabi-funnel-setup/",
    copy: "Lead capture, offer flow, checkout journey, and conversion path planning inside Kajabi.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>`
  },
  {
    title: "Kajabi Email Automation",
    route: "/kajabi-email-automation/",
    copy: "Welcome sequences, nurture emails, launch emails, reminders, and student communication flows.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>`
  },
  {
    title: "Kajabi Course Migration",
    route: "/kajabi-course-migration/",
    copy: "Move course content from WordPress, PDFs, drives, or other platforms into a structured Kajabi experience.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>`
  },
  {
    title: "Kajabi Templates",
    route: "/kajabi-templates/",
    copy: "Reusable layout and design systems for faster Kajabi page creation.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>`
  },
  {
    title: "Kajabi Support & Maintenance",
    route: "/kajabi-support/",
    copy: "Ongoing updates, cleanup, page fixes, content adjustments, and launch support.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>`
  }
];
---
<section class="py-20 md:py-28 bg-brand-softBg relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-primary mb-4">Kajabi services built around your full launch journey</h2>
      <p class="text-lg text-brand-textMuted max-w-2xl">Start with one service or build the full system step by step.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <a href={service.route} class="group bg-white border border-brand-border rounded-xl p-6 hover-lift hover:border-brand-accent/50 focus-ring transition-all duration-300 flex flex-col h-full relative overflow-hidden">

          <div class="absolute top-0 right-0 w-24 h-24 bg-brand-softGreen rounded-bl-full -mr-12 -mt-12 transition-transform duration-500 group-hover:scale-110 opacity-50"></div>

          <div class="w-10 h-10 rounded-lg bg-brand-softBlue text-brand-primary flex items-center justify-center mb-5 relative z-10">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon}></svg>
          </div>

          <h3 class="text-lg font-bold text-brand-primary mb-3 relative z-10 group-hover:text-brand-accent transition-colors">{service.title}</h3>

          <p class="text-sm text-brand-textMuted mb-6 flex-grow relative z-10">{service.copy}</p>

          <div class="flex items-center text-brand-primary font-semibold text-sm mt-auto relative z-10 group-hover:text-brand-accent transition-colors">
            Learn more
            <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
