---
---
<section class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-brand-softBg">
  <!-- Subtle background texture -->
  <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--brand-blue) 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">

      <!-- Text Content -->
      <div class="max-w-2xl animate-fade-up">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-brand-softGreen text-brand-primary text-sm font-semibold mb-6 border border-brand-accent/20">
          <span class="w-2 h-2 rounded-full bg-brand-accent mr-2"></span>
          Kajabi Website & Course Launch Agency
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-primary leading-tight mb-6">
          Build a Kajabi Website That Looks Professional, Sells Clearly, and Launches Faster
        </h1>

        <p class="text-lg md:text-xl text-brand-textMuted mb-6 leading-relaxed">
          TheEduAssist helps course creators, coaches, consultants, and education businesses design Kajabi websites, landing pages, funnels, courses, and email systems that are ready to launch.
        </p>

        <div class="flex flex-wrap items-center gap-3 text-sm text-brand-textMain mb-8 font-medium">
          <span>Website design</span> <span class="text-brand-accent">•</span>
          <span>Course setup</span> <span class="text-brand-accent">•</span>
          <span>Funnels</span> <span class="text-brand-accent">•</span>
          <span>Email automation</span> <span class="text-brand-accent">•</span>
          <span>Migration</span> <span class="text-brand-accent">•</span>
          <span>Launch support</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mb-4">
          <a href="/book-free-kajabi-audit/" class="inline-flex justify-center items-center px-8 py-3.5 border border-transparent text-base font-bold rounded-lg text-white bg-brand-accent hover:bg-brand-primary focus-ring hover-lift click-press shadow-sm transition-all text-center">
            Book Free Kajabi Audit
          </a>
          <a href="/kajabi-services/" class="inline-flex justify-center items-center px-8 py-3.5 border border-brand-border text-base font-bold rounded-lg text-brand-primary bg-white hover:bg-brand-softBg focus-ring hover-lift click-press shadow-sm transition-all text-center">
            View Kajabi Services
          </a>
        </div>

        <p class="text-xs text-brand-textMuted max-w-md">
          Kajabi is a third-party platform. Platform support does not imply official partnership unless stated.
        </p>
      </div>

      <!-- Custom Visual -->
      <div class="relative lg:ml-auto w-full max-w-lg lg:max-w-none animate-fade-up" style="animation-delay: 0.1s;">
        <!-- SR Only description -->
        <p class="sr-only">A dashboard-style diagram showing the Kajabi launch system with interconnected cards for Website, Course, Funnel, Email, Migration, and Student Experience pointing to Launch Review.</p>

        <div class="relative bg-white rounded-2xl shadow-xl border border-brand-border p-6 md:p-8 overflow-hidden z-10">

          <div class="absolute top-0 right-0 -mr-16 -mt-16 w-32 h-32 bg-brand-softGreen rounded-full opacity-50 blur-2xl"></div>
          <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-32 h-32 bg-brand-softBlue rounded-full opacity-50 blur-2xl"></div>

          <div class="text-center mb-8 relative z-10">
            <h3 class="text-xl font-bold text-brand-primary mb-2">Kajabi Launch System</h3>
            <p class="text-xs text-brand-textMuted">Built for course creators, coaches, consultants, and learning businesses that need a cleaner online course system.</p>
          </div>

          <!-- Flow Diagram -->
          <div class="relative z-10">
            <!-- Center Line -->
            <div class="absolute left-1/2 top-4 bottom-4 w-0.5 bg-brand-accent/30 -translate-x-1/2 z-0 hidden sm:block"></div>

            <div class="space-y-4 relative z-10">

              <!-- Row 1 -->
              <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="w-full sm:w-5/12 bg-white border border-brand-border shadow-sm rounded-lg p-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-md bg-brand-softBlue text-brand-primary flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                  </div>
                  <span class="font-semibold text-sm text-brand-primary">Website</span>
                </div>
                <div class="hidden sm:block w-2/12 relative">
                  <div class="absolute top-1/2 left-0 w-full h-0.5 bg-brand-accent/30 -translate-y-1/2"></div>
                </div>
                <div class="w-full sm:w-5/12 bg-white border border-brand-border shadow-sm rounded-lg p-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-md bg-brand-softGreen text-brand-accent flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                  </div>
                  <span class="font-semibold text-sm text-brand-primary">Course</span>
                </div>
              </div>

              <!-- Row 2 -->
              <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="w-full sm:w-5/12 bg-white border border-brand-border shadow-sm rounded-lg p-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-md bg-brand-softBlue text-brand-primary flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                  </div>
                  <span class="font-semibold text-sm text-brand-primary">Funnel</span>
                </div>
                <div class="hidden sm:block w-2/12 relative">
                  <div class="absolute top-1/2 left-0 w-full h-0.5 bg-brand-accent/30 -translate-y-1/2"></div>
                </div>
                <div class="w-full sm:w-5/12 bg-white border border-brand-border shadow-sm rounded-lg p-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-md bg-brand-softBlue text-brand-primary flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  </div>
                  <span class="font-semibold text-sm text-brand-primary">Email</span>
                </div>
              </div>

              <!-- Row 3 -->
              <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="w-full sm:w-5/12 bg-white border border-brand-border shadow-sm rounded-lg p-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-md bg-brand-softBlue text-brand-primary flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                  </div>
                  <span class="font-semibold text-sm text-brand-primary">Migration</span>
                </div>
                <div class="hidden sm:block w-2/12 relative">
                  <div class="absolute top-1/2 left-0 w-full h-0.5 bg-brand-accent/30 -translate-y-1/2"></div>
                </div>
                <div class="w-full sm:w-5/12 bg-white border border-brand-border shadow-sm rounded-lg p-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-md bg-brand-softBlue text-brand-primary flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  <span class="font-semibold text-sm text-brand-primary">Student Exp.</span>
                </div>
              </div>

              <!-- Final Step -->
              <div class="pt-4 flex justify-center">
                <div class="w-full sm:w-2/3 bg-brand-primary border border-brand-navy shadow-md rounded-lg p-3 flex items-center justify-center gap-3 text-white">
                  <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <span class="font-bold text-base">Launch Review</span>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
