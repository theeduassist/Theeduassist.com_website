---
const reasons = [
  {
    title: "E-learning structure first",
    copy: "We think beyond page design and organize the learning journey, course flow, and student experience.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>`
  },
  {
    title: "Kajabi launch system thinking",
    copy: "We connect website pages, offers, funnels, emails, checkout paths, and student access.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>`
  },
  {
    title: "Practical, clean design",
    copy: "We use professional layouts that make your offer easier to understand without overloading the page.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>`
  },
  {
    title: "No fake promises",
    copy: "We do not guarantee sales or revenue. We focus on clarity, structure, launch readiness, and learner experience.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>`
  }
];
---
<section class="py-20 md:py-28 bg-brand-softBg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-primary">Why TheEduAssist</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {reasons.map((reason) => (
        <div class="bg-white border border-brand-border rounded-xl p-8 shadow-sm flex items-start gap-6 hover-lift hover:border-brand-accent/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-brand-softBlue text-brand-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={reason.icon}></svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-brand-primary mb-3">{reason.title}</h3>
            <p class="text-brand-textMuted leading-relaxed">{reason.copy}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
