<div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>

<!-- Fallback AI Modal -->
<div id="footer-ai-fallback-modal" class="fixed inset-0 z-[100] hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm fallback-modal-bg"></div>
    <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg border border-slate-200 overflow-hidden transform transition-all">
        <div class="bg-brand-softBg px-6 py-4 border-b border-brand-border/50 flex justify-between items-center">
            <h3 class="text-lg font-bold text-brand-primary">Copy Prompt</h3>
            <button type="button" class="fallback-modal-close text-slate-400 hover:text-brand-primary focus-ring rounded-md p-1">
                <span class="sr-only">Close</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="p-6">
            <p class="text-sm text-slate-600 mb-4">We couldn't copy the prompt automatically. Please copy the text below and paste it into your AI assistant.</p>
            <div class="relative group">
                <pre id="footer-ai-fallback-prompt" class="bg-slate-50 border border-slate-200 rounded-md p-4 text-xs text-slate-700 font-mono whitespace-pre-wrap max-h-48 overflow-y-auto"></pre>
                <button type="button" id="footer-ai-fallback-copy-btn" class="absolute top-2 right-2 bg-white border border-slate-200 text-slate-500 hover:text-brand-primary p-1.5 rounded focus-ring shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                </button>
            </div>
            <div id="footer-ai-fallback-success" class="text-brand-accent text-xs font-bold mt-2 opacity-0 transition-opacity">Copied!</div>
        </div>
        <div class="bg-slate-50 px-6 py-4 border-t border-slate-100 flex justify-end space-x-3">
            <button type="button" class="fallback-modal-close px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-900 focus-ring rounded-md transition-colors">Cancel</button>
            <a id="footer-ai-fallback-open-btn" href="https://chatgpt.com/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 text-sm font-bold text-white bg-brand-primary hover:bg-brand-navy rounded-md focus-ring transition-colors shadow-sm inline-flex items-center">
                Open AI
                <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
        </div>
    </div>
</div>

<script>
    import { generatePrompt } from '../ai/AIAssistClient';
    import { shareLinks } from '../../data/shareLinks';

    function showToast(message: string) {
        const container = document.getElementById('toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = 'bg-brand-navy border border-brand-accent/30 text-white px-4 py-3 rounded shadow-lg transform transition-all duration-300 translate-y-full opacity-0 flex items-center space-x-2';
        toast.innerHTML = `
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-sm font-medium">${message}</span>
        `;

        container.appendChild(toast);

        // Animate in
        requestAnimationFrame(() => {
            toast.classList.remove('translate-y-full', 'opacity-0');
        });

        // Remove after delay
        setTimeout(() => {
            toast.classList.add('translate-y-full', 'opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }

    document.addEventListener('DOMContentLoaded', async () => {
        const fallbackModal = document.getElementById('footer-ai-fallback-modal');
        const fallbackPrompt = document.getElementById('footer-ai-fallback-prompt');
        const fallbackCopyBtn = document.getElementById('footer-ai-fallback-copy-btn');
        const fallbackOpenBtn = document.getElementById('footer-ai-fallback-open-btn') as HTMLAnchorElement;
        const fallbackSuccess = document.getElementById('footer-ai-fallback-success');
        const closeBtns = document.querySelectorAll('.fallback-modal-close, .fallback-modal-bg');

        function openFallbackModal(prompt: string, url: string) {
            if (!fallbackModal || !fallbackPrompt || !fallbackOpenBtn) return;
            fallbackPrompt.textContent = prompt;
            fallbackOpenBtn.href = url;

            fallbackModal.classList.remove('hidden');
            // reflow
            void fallbackModal.offsetWidth;
            fallbackModal.classList.remove('opacity-0');
            fallbackModal.classList.add('opacity-100');
        }

        function closeFallbackModal() {
            if (!fallbackModal) return;
            fallbackModal.classList.remove('opacity-100');
            fallbackModal.classList.add('opacity-0');
            setTimeout(() => {
                fallbackModal.classList.add('hidden');
            }, 300);
        }

        closeBtns.forEach(btn => btn.addEventListener('click', closeFallbackModal));

        if (fallbackCopyBtn && fallbackPrompt) {
            fallbackCopyBtn.addEventListener('click', async () => {
                try {
                    await navigator.clipboard.writeText(fallbackPrompt.textContent || '');
                    if (fallbackSuccess) {
                        fallbackSuccess.classList.remove('opacity-0');
                        fallbackSuccess.classList.add('opacity-100');
                        setTimeout(() => {
                            fallbackSuccess.classList.remove('opacity-100');
                            fallbackSuccess.classList.add('opacity-0');
                        }, 3000);
                    }
                } catch (err) {
                    console.error('Manual copy failed', err);
                }
            });
        }

        // AI Buttons
        const { copyAndOpenAI } = await import('../ai/AIAssistClient');
        const aiBtns = document.querySelectorAll('.ai-utility-btn');
        aiBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const url = target.dataset.aiUrl || '';
                const name = target.dataset.aiName || '';

                // Use the shared handler
                await copyAndOpenAI('summarize_page', url, name);
            });
        });

        // Global listener for show-ai-modal if dispatched by AIAssistClient
        window.addEventListener('show-ai-modal', (e: Event) => {
            const customEvent = e as CustomEvent;
            if (customEvent.detail) {
                openFallbackModal(customEvent.detail.prompt, customEvent.detail.platformUrl);
            }
        });

    });
</script>
