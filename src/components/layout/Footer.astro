---
import { getSiteSettings } from '../../sanity/queries';
import { shareLinks } from '../../data/shareLinks';

const siteSettings = await getSiteSettings();
const site = siteSettings || { name: 'TheEduAssist', email: 'Info@theeduassist.com', social: {} };

const navigation = {
    services: [
        { label: 'Course Creation', href: '/services/' },
        { label: 'Curriculum Design', href: '/services/' },
        { label: 'Kajabi Setup', href: '/kajabi-services/' },
        { label: 'LMS Migration', href: '/services/lms-implementation-migration/' },
        { label: 'Content Conversion', href: '/services/' },
        { label: 'Funnels & Automation', href: '/services/' },
        { label: 'Ongoing Support', href: '/services/' }
    ],
    solutions: [
        { label: 'For Creators & Coaches', href: '/' },
        { label: 'For Consultants', href: '/' },
        { label: 'For Educators', href: '/' },
        { label: 'For Training Companies', href: '/' },
        { label: 'For Online Academies', href: '/' },
        { label: 'For Businesses', href: '/' }
    ],
    resources: [
        { label: 'Blog', href: '/blog/' },
        { label: 'Case Studies', href: '/case-studies/' },
        { label: 'Sitemap', href: '/sitemap/' },
        { label: 'Contact', href: '/contact/' }
    ],
    company: [
        { label: 'About', href: '/about/' },
        { label: 'Services', href: '/services/' },
        { label: 'Careers', href: '/careers/' },
        { label: 'Privacy Policy', href: '/privacy-policy/' },
        { label: 'Terms & Conditions', href: '/terms-and-conditions/' }
