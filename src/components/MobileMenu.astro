---
const { navigation = { header: [] } } = Astro.props;
---
<nav class="md:hidden">
  <details class="relative">
    <summary class="flex items-center gap-2 cursor-pointer px-3 py-2 rounded-md focus-ring bg-white border border-slate-200">
      Menu
    </summary>
    <div class="absolute right-0 mt-2 w-64 bg-white border border-slate-200 rounded-md shadow-lg z-50">
      <ul class="p-4 space-y-2">
        {navigation.header.map(item => (
          <li>
            <a href={item.href} class="block px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 rounded">{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </details>
</nav>
