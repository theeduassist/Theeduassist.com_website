---
import AISummaryPromptModal from './AISummaryPromptModal.astro';
---
<div class="fixed bottom-0 left-0 w-full bg-white border-t border-slate-200 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] z-40 transform translate-y-full transition-transform duration-300" id="ai-assist-bar">
  <div class="container mx-auto px-4 py-3 flex flex-col sm:flex-row items-center justify-between max-w-4xl">
    <div class="flex items-center mb-2 sm:mb-0">
      <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center mr-3 text-[var(--color-primary)]">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <span class="text-sm font-medium text-slate-700">Summarize this page with AI</span>
    </div>

    <button
      type="button"
      id="open-ai-modal-btn"
      class="text-sm bg-slate-900 text-white px-5 py-2 rounded-md hover:bg-slate-800 transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-slate-900 focus:outline-none flex items-center"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="ai-summary-modal"
    >
      Open AI Assistant
    </button>
  </div>
</div>

<AISummaryPromptModal />

<script>
  function setupAIAssistBar() {
    const bar = document.getElementById('ai-assist-bar');

    // Only show the bar after scrolling a bit to not clutter initial view
    const handleScroll = () => {
      if (!bar) return;
      if (window.scrollY > 300) {
        bar.classList.remove('translate-y-full');
      } else {
        bar.classList.add('translate-y-full');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Check on init
  }

  setupAIAssistBar();
  document.addEventListener('astro:page-load', setupAIAssistBar);
</script>
