---
import BlogArticleLayout from '../../layouts/BlogArticleLayout.astro';
import ArticleMetaBar from '../../components/blog/ArticleMetaBar.astro';
import BlogTableOfContents from '../../components/blog/BlogTableOfContents.astro';
import ArticleShareButtons from '../../components/blog/ArticleShareButtons.astro';
import RelatedArticles from '../../components/blog/RelatedArticles.astro';
import RelatedCaseStudies from '../../components/blog/RelatedCaseStudies.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import { blogPosts } from '../../data/blogPosts';
import { fetchFromSanity } from '../../sanity/client';
import { latestBlogPostsQuery } from '../../sanity/queries';

export async function getStaticPaths() {
  // Try to fetch from Sanity first
  let sanityPosts = [];
  try {
    sanityPosts = await fetchFromSanity(latestBlogPostsQuery, { status: 'published' }) || [];
  } catch (e) {
    console.warn("Could not fetch Sanity posts for static paths, falling back to static posts.");
  }

  // Combine logic
  const publishedStaticPosts = blogPosts.filter(post => post.status === 'published');

  // Map Sanity posts to have strings for slugs to match static structure
  const formattedSanityPosts = sanityPosts.map(p => ({
    ...p,
    slug: p.slug?.current || p.slug
  }));

  // Combine all posts
  const allUnifiedPosts = [...formattedSanityPosts];

  publishedStaticPosts.forEach(staticPost => {
    if (!formattedSanityPosts.find(p => p.slug === staticPost.slug)) {
       allUnifiedPosts.push(staticPost);
    }
  });

  return allUnifiedPosts.map(post => ({
    params: { slug: post.slug },
    props: { post, allUnifiedPosts }
  }));
}

const { post, allUnifiedPosts } = Astro.props;

if (!post) {
  return new Response("Post not found", { status: 404 });
}

// Ensure schema attributes match requirements (no fake author/dates if not real)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.seoTitle || post.title,
  "description": post.seoDescription || post.excerpt,
  "author": post.author ? { "@type": "Organization", "name": post.author } : undefined,
  "datePublished": post.publishedAt || undefined,
  "dateModified": post.updatedAt || post.publishedAt || undefined,
  "image": post.heroImage || post.featuredImage?.asset?.url ? `https://theeduassist.com${post.heroImage || post.featuredImage?.asset?.url}` : undefined,
  "publisher": {
    "@type": "Organization",
    "name": "TheEduAssist",
    "url": "https://theeduassist.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://theeduassist.com/blog/${post.slug.current || post.slug}/`
  }
};
---

<BlogArticleLayout
  title={post.seoTitle || `${post.title} | TheEduAssist Blog`}
  description={post.seoDescription || post.excerpt}
  canonicalPath={post.canonicalUrl || `/blog/${post.slug.current || post.slug}/`}
  ogImage={post.heroImage || post.featuredImage?.asset?.url}
  type="article"
  jsonLd={[articleSchema]}
>
  <article class="container mx-auto px-4 py-16 max-w-4xl">
    <header class="mb-10 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-slate-800 leading-tight">
        {post.title}
      </h1>
      <p class="text-xl text-slate-600 mb-8 leading-relaxed">
        {post.excerpt}
      </p>
    </header>

    {post.heroImage && (
      <div class="mb-12 rounded-xl overflow-hidden shadow-md">
        <img
          src={post.heroImage}
          alt={post.heroImageAlt || post.title}
          class="w-full h-auto object-cover aspect-video"
          loading="eager"
        />
      </div>
    )}

    <div class="max-w-3xl mx-auto">
      <nav class="text-sm text-slate-500 mb-6" aria-label="Breadcrumb">
        <ol class="list-none p-0 inline-flex">
          <li class="flex items-center">
            <a href="/" class="hover:text-[var(--color-primary)]">Home</a>
            <svg class="fill-current w-3 h-3 mx-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"/></svg>
          </li>
          <li class="flex items-center">
            <a href="/blog/" class="hover:text-[var(--color-primary)]">Resources</a>
            <svg class="fill-current w-3 h-3 mx-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"/></svg>
          </li>
          <li>
            <span class="text-slate-700" aria-current="page">{post.title}</span>
          </li>
        </ol>
      </nav>

      <ArticleMetaBar
        category={post.category}
        publishedAt={post.publishedAt}
        updatedAt={post.updatedAt}
        author={post.author}
        readTimeMinutes={post.readingTime}
      />

      <div class="flex flex-col md:flex-row gap-10 mt-10">
        <!-- Main Content -->
        <div class="md:w-full prose prose-lg prose-slate prose-a:text-[var(--color-primary)] hover:prose-a:text-[var(--color-accent)] max-w-none">
          <div set:html={post.content || "<p>Content coming soon.</p>"} />

          <ArticleShareButtons
            url={`https://theeduassist.com/blog/${post.slug.current || post.slug}/`}
            title={post.title}
          />
        </div>
      </div>
    </div>

    <!-- Tags -->
    {post.tags && post.tags.length > 0 && (
      <div class="max-w-3xl mx-auto mt-8 mb-16">
        <div class="flex flex-wrap gap-2">
          {post.tags.map(tag => (
            <span class="px-3 py-1 bg-slate-100 text-slate-600 text-sm rounded-full">
              {tag.replace(/-/g, ' ')}
            </span>
          ))}
        </div>
      </div>
    )}

    <div class="max-w-4xl mx-auto mt-16 pt-8">
        <RelatedCaseStudies
          slugs={post.relatedCaseStudies}
          category={post.category}
        />

        <!-- Final CTA Update -->
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8 md:p-12 text-center my-12 shadow-sm relative overflow-hidden">
          <div class="relative z-10 max-w-2xl mx-auto">
            <h2 class="text-3xl font-bold text-slate-800 mb-4">Need help turning this into a working course system?</h2>
            <p class="text-slate-600 mb-8 text-lg">
              Share your course, Kajabi, LMS, content, or launch problem and TheEduAssist will reply within 24–48 hours with the best service path, estimated scope, and next step.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/book-free-audit/" class="blog-cta-btn inline-flex items-center justify-center px-8 py-4 bg-[var(--color-accent)] text-white font-bold rounded-lg hover:bg-opacity-90 transition-transform hover:-translate-y-0.5 focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-accent)] focus:outline-none" data-cta-label="Get 24–48 Hour Review">
                Get 24–48 Hour Review &rarr;
              </a>
              <a href="/services/" class="blog-cta-btn inline-flex items-center justify-center px-8 py-4 bg-transparent border border-slate-300 text-slate-700 font-bold rounded-lg hover:bg-slate-100 transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 focus:outline-none" data-cta-label="View Services">
                View Services & Starting Prices
              </a>
            </div>
          </div>
        </div>

        <RelatedArticles
          currentSlug={post.slug.current || post.slug}
          category={post.category}
          tags={post.tags}
          allPosts={allUnifiedPosts}
        />
    </div>
  </article>
</BlogArticleLayout>
