---
import Layout from "../../layouts/Layout.astro";
import HomeHero from "../../components/sections/HomeHero.astro";
import { getAllPosts } from '../../sanity/queries';

const posts = await getAllPosts();
---
<Layout title="Blog" description="TheEduAssist Blog - Insights on eLearning, Kajabi, and LMS solutions.">

  <HomeHero
    title="TheEduAssist Blog"
    subtitle="Insights and practical advice on course design, platform setup, and eLearning strategy."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
  />

  <section class="py-24 bg-white text-center px-4">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-left">
        <h1 class="text-3xl font-bold">Blog</h1>
        <p class="text-slate-600">Latest articles and guides on eLearning and Kajabi.</p>
      </div>

      {posts && posts.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-8">
          {posts.map(post => (
            <article class="bg-slate-50 p-6 rounded-lg border border-slate-200">
              <h2 class="text-xl font-bold mb-2"><a href={`/blog/${post.slug?.current || ''}/`} class="text-blue-600 hover:underline">{post.title}</a></h2>
              <div class="text-sm text-slate-500 mb-4">{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : 'Unpublished'}</div>
              <p class="text-slate-700">{(post.content && post.content[0] && post.content[0].children && post.content[0].children[0] && post.content[0].children[0].text) || (post.excerpt) || ''}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="max-w-3xl mx-auto bg-slate-50 p-10 rounded-lg border border-slate-200">
          <h2 class="text-2xl font-bold mb-4 text-slate-900">Content Migration in Progress</h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">
            No published posts found. Create and publish `post` documents in Sanity Studio to show them here.
          </p>
          <a href="/services/" class="text-blue-600 font-medium hover:underline">Explore our services in the meantime &rarr;</a>
        </div>
      )}
    </div>
  </section>

</Layout>
