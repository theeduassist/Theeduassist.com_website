---
import Layout from '../../layouts/Layout.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import BlogSearchFilters from '../../components/blog/BlogSearchFilters.astro';
import BlogCategoryCards from '../../components/blog/BlogCategoryCards.astro';
import FeaturedResourceGrid from '../../components/blog/FeaturedResourceGrid.astro';
import BlogMigrationFlow from '../../components/blog/BlogMigrationFlow.astro';
import TopicClusterMap from '../../components/blog/TopicClusterMap.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import AIPageAssistBar from '../../components/blog/AIPageAssistBar.astro';

import LatestArticles from '../../components/blog/LatestArticles.astro';

// SEO details
const title = "Blog & Resources | E-Learning, Kajabi, LMS & Course Design Insights | TheEduAssist";
const description = "Read practical guides from TheEduAssist on course creation, Kajabi setup, LMS migration, content conversion, AI-powered e-learning, funnels, and online course support.";
const canonicalPath = "/blog/";
const ogTitle = title;
const ogDescription = description;

// Basic WebPage schema for the hub
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": `https://theeduassist.com${canonicalPath}`,
  "publisher": {
    "@type": "Organization",
    "name": "TheEduAssist",
    "url": "https://theeduassist.com"
  }
};
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  jsonLd={[schema]}
>
  <BlogHero />

  <main class="container mx-auto px-4 py-12 max-w-6xl">
    <div class="mb-12">
        <BlogSearchFilters />
    </div>

    <BlogCategoryCards />

    <FeaturedResourceGrid />

    <LatestArticles />

    <div class="my-16">
        <BlogMigrationFlow />
    </div>

    <TopicClusterMap />

    <div class="mt-20">
        <BlogCTA />
    </div>
  </main>

  <AIPageAssistBar />
</Layout>
