---
import Layout from '../../layouts/Layout.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import BlogSearchFilters from '../../components/blog/BlogSearchFilters.astro';
import BlogCategoryCards from '../../components/blog/BlogCategoryCards.astro';
import FeaturedResourceGrid from '../../components/blog/FeaturedResourceGrid.astro';
import BlogMigrationFlow from '../../components/blog/BlogMigrationFlow.astro';
import TopicClusterMap from '../../components/blog/TopicClusterMap.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import AIPageAssistBar from '../../components/blog/AIPageAssistBar.astro';

// SEO details
const title = "TheEduAssist Blog | Kajabi, Course Creation & E-Learning Design Resources";
const description = "Explore practical resources from TheEduAssist on Kajabi websites, course setup, funnels, email automation, LMS migration, AI learning, instructional design, and e-learning strategy.";
const canonicalPath = "/blog/";
const ogTitle = "TheEduAssist Blog";
const ogDescription = "Guides and resources for building better Kajabi websites, courses, funnels, and e-learning systems.";

// Basic WebPage schema for the hub
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": `https://theeduassist.com${canonicalPath}`,
  "publisher": {
    "@type": "Organization",
    "name": "TheEduAssist",
    "url": "https://theeduassist.com"
  }
};
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  jsonLd={[schema]}
>
  <BlogHero />

  <main class="container mx-auto px-4 py-12 max-w-6xl">
    <div class="mb-12">
        <BlogSearchFilters />
    </div>

    <BlogCategoryCards />

    <FeaturedResourceGrid />

    <!-- "Latest Articles" section will go here when real reviewed posts exist -->

    <div class="my-16">
        <BlogMigrationFlow />
    </div>

    <TopicClusterMap />

    <div class="mt-20">
        <BlogCTA />
    </div>
  </main>

  <AIPageAssistBar />
</Layout>
