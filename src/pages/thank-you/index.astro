---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Thank You" description="Thank you for contacting TheEduAssist.">

        <section class="py-32 bg-slate-50 text-center px-4 flex-grow flex flex-col justify-center items-center">
            <h1 class="text-4xl font-bold text-slate-900 mb-6">Thank You</h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10">Thank you for contacting TheEduAssist. Your request has been received. Our team will review your details and respond with the next step.</p>
            <a href="/" class="text-blue-600 font-medium hover:underline">&larr; Return to Homepage</a>
        </section>

</Layout>
