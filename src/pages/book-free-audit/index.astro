---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Book Free Audit" description="Book a free audit with TheEduAssist to review your course structure, platform setup, and launch strategy.">

        <section class="py-20 bg-slate-100 text-center px-4 border-b border-slate-200">
            <h1 class="text-5xl font-bold text-slate-900 mb-6 max-w-4xl mx-auto">Book Your Free eLearning Audit</h1>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto">A professional, no-obligation review of your course, platform, or content structure.</p>
        </section>

        <section class="py-20 bg-white">
            <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12">
                <div>
                    <h2 class="text-3xl font-bold mb-6">What the audit includes</h2>
                    <ul class="list-disc pl-5 space-y-3 text-lg text-slate-600 mb-10">
                        <li>Course or platform review</li>
                        <li>Kajabi or LMS setup review</li>
                        <li>Content structure review</li>
                        <li>User journey review</li>
                    </ul>

                    <h2 class="text-3xl font-bold mb-6">Who it is for</h2>
                    <p class="text-lg text-slate-600 mb-10">Coaches, course creators, corporate training teams, and educational organizations looking to improve or launch their digital learning programs.</p>

                    <h2 class="text-3xl font-bold mb-6">What you get after</h2>
                    <ul class="list-disc pl-5 space-y-3 text-lg text-slate-600">
                        <li>A clear launch roadmap</li>
                        <li>Actionable feedback on your current setup</li>
                        <li>A next-step proposal tailored to your needs</li>
                    </ul>
                </div>

                <div class="bg-slate-50 p-8 rounded-lg border border-slate-200 text-center flex flex-col justify-center">
                    <h3 class="text-2xl font-bold mb-6">Ready to start?</h3>
                    <p class="text-slate-600 mb-8">Reach out to us directly to schedule your audit call.</p>
                    <a href="/contact/" class="bg-blue-600 text-white px-8 py-4 rounded-md font-bold text-lg shadow-sm hover:bg-blue-700">Contact Us to Schedule</a>
                </div>
            </div>
        </section>

</Layout>
