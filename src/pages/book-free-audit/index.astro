---
import Layout from "../../layouts/Layout.astro";
import AuditHero from "../../components/audit/AuditHero.astro";
import AuditReviewScope from "../../components/audit/AuditReviewScope.astro";
import AuditRequestForm from "../../components/forms/AuditRequestForm.astro";
import CalendlyCTA from "../../components/audit/CalendlyCTA.astro";
import AuditNextSteps from "../../components/audit/AuditNextSteps.astro";
import AuditFAQ from "../../components/audit/AuditFAQ.astro";
import { webPageSchema, faqPageSchema, breadcrumbSchema } from '../../lib/schema';

// Required FAQ array for the Schema
const auditFaqs = [
  {
    question: "Is the audit really free?",
    answer: "Yes. The audit request helps us understand your project and recommend the right next step. Full implementation work is quoted separately."
  },
  {
    question: "Do I need to have course content ready?",
    answer: "No. You can submit an idea, rough notes, existing content, Kajabi setup, LMS, or scattered files."
  },
  {
    question: "Can you review my Kajabi setup?",
    answer: "Yes. Kajabi is one of our strongest specialties."
  },
  {
    question: "Can you review LMS or WordPress content?",
    answer: "Yes. We can review LMS content, WordPress course pages, Google Drive folders, PDFs, videos, and other training materials."
  },
  {
    question: "Will you give pricing?",
    answer: "We can recommend a package or custom quote after reviewing your audit details. Pricing depends on scope, content volume, platform, timeline, and launch needs."
  },
  {
    question: "Do you guarantee sales?",
    answer: "No. We help improve structure, learning experience, platform setup, funnels, and launch readiness, but sales depend on offer, audience, traffic, pricing, trust, and other factors."
  }
];

const jsonLd = [
  webPageSchema(
    "Book a Free Course Audit | TheEduAssist",
    "Book a free audit with TheEduAssist to review your course idea, Kajabi setup, LMS, training content, AI-powered e-learning needs, funnels, automation, or launch workflow.",
    "/book-free-audit/"
  ),
  faqPageSchema(auditFaqs),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Book Free Audit", urlPath: "/book-free-audit/" }
  ])
];

const trustChips = [
  "Free Audit",
  "Course Review",
  "Kajabi Review",
  "LMS Review",
  "Content Review",
  "Funnel Review",
  "Launch Review"
];
---
<Layout
  title="Book a Free Course Audit | TheEduAssist"
  description="Book a free audit with TheEduAssist to review your course idea, Kajabi setup, LMS, training content, AI-powered e-learning needs, funnels, automation, or launch workflow."
  canonicalPath="/book-free-audit/"
  jsonLd={jsonLd}
>

  <AuditHero
    title="Book a Free Course, Kajabi, or LMS Audit"
    subtitle="Tell us what you are building, improving, migrating, or launching. TheEduAssist will review your course idea, content, Kajabi setup, LMS, funnel, or learning workflow and recommend the best next step."
    primaryCtaLabel="Start Audit Form"
    primaryCtaLink="#audit-form-section"
    secondaryCtaLabel="Email Instead"
    secondaryCtaLink="mailto:Info@theeduassist.com"
    trustChips={trustChips}
  />

  <AuditReviewScope />

  <section id="audit-form-section" class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white p-8 md:p-10 rounded-xl border border-slate-200 shadow-sm">
        <h2 class="text-3xl font-bold mb-8 text-center text-slate-900">Tell Us About Your Project</h2>
        <AuditRequestForm />
      </div>
    </div>
  </section>

  <CalendlyCTA />

  <AuditNextSteps />

  <AuditFAQ />

</Layout>
