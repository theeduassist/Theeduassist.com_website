---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | TheEduAssist">
  <main class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl font-bold mb-6 text-gray-900">Page Not Found</h1>
    <p class="text-lg text-gray-700 mb-8 max-w-2xl mx-auto">
      We could not find that page. TheEduAssist has been reorganizing its website, so the page may have moved. You can explore our services, visit the Kajabi Services page, or book a free audit.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 px-6 rounded transition-colors">
        Home
      </a>
      <a href="/services/" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded transition-colors">
        Services
      </a>
      <a href="/kajabi-services/" class="bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 px-6 rounded transition-colors">
        Kajabi Services
      </a>
      <a href="/book-free-audit/" class="bg-[#F6C343] hover:bg-[#e5b331] text-gray-900 font-medium py-2 px-6 rounded transition-colors">
        Book Free Audit
      </a>
      <a href="/contact/" class="bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-2 px-6 rounded transition-colors">
        Contact
      </a>
    </div>
  </main>
</Layout>
