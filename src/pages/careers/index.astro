---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Careers" description="Career opportunities at TheEduAssist.">

        <section class="py-32 bg-white text-center px-4 flex-grow flex flex-col justify-center items-center">
            <h1 class="text-5xl font-bold text-slate-900 mb-6">Careers</h1>
            <div class="bg-slate-50 border border-slate-200 p-8 rounded-lg max-w-2xl mx-auto">
                <p class="text-lg text-slate-700">TheEduAssist occasionally opens remote internship and project-based roles. Current openings will be listed here when available.</p>
            </div>
        </section>

</Layout>
