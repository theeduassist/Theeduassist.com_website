---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="AI-Powered eLearning" description="TheEduAssist uses AI carefully to support course planning, content structuring, learner engagement, and training workflows.">

        <section class="py-20 bg-slate-100 text-center px-4">
            <h1 class="text-5xl font-bold text-slate-900 mb-6 max-w-4xl mx-auto leading-tight">AI-Powered eLearning</h1>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto mb-10">TheEduAssist uses AI carefully to support course planning, content structuring, learner engagement, assessments, and training workflows while keeping human review at the center.</p>
            <a href="/book-free-audit/" class="bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700">Book Free Audit</a>
        </section>

        <section class="py-20 bg-white">
            <div class="max-w-4xl mx-auto px-4">
                <h2 class="text-3xl font-bold mb-6">Use Cases & Capabilities</h2>
                <ul class="list-disc pl-5 space-y-3 text-slate-600 mb-10">
                    <li>Accelerated content structuring and outlining</li>
                    <li>Automated assessment and quiz generation</li>
                    <li>Personalized learner feedback models</li>
                    <li>Streamlined training administration workflows</li>
                </ul>

                <div class="bg-blue-50 p-6 rounded-lg border border-blue-100">
                    <h3 class="font-bold text-blue-900 mb-2">Human Review and Quality Control</h3>
                    <p class="text-blue-800 text-sm">Responsible AI Note: We believe AI is a tool to enhance, not replace, human expertise. All AI-assisted content and structures undergo rigorous human review to ensure accuracy, pedagogical soundness, and alignment with your specific goals.</p>
                </div>
            </div>
        </section>

</Layout>
