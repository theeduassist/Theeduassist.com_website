---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Custom eLearning Development" description="Custom eLearning Development helps organizations turn raw training material into structured, interactive, learner-friendly digital courses.">

        <section class="py-20 bg-slate-100 text-center px-4">
            <h1 class="text-5xl font-bold text-slate-900 mb-6 max-w-4xl mx-auto leading-tight">Custom eLearning Development</h1>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto mb-10">Custom eLearning Development helps organizations turn raw training material into structured, interactive, learner-friendly digital courses.</p>
            <a href="/book-free-audit/" class="bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700">Book Free Audit</a>
        </section>

        <section class="py-20 bg-white">
            <div class="max-w-4xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12">
                <div>
                    <h2 class="text-3xl font-bold mb-6">What We Build</h2>
                    <p class="text-slate-600 mb-4">We create engaging digital learning experiences tailored specifically to your audience's needs and your organization's goals.</p>
                    <h2 class="text-3xl font-bold mt-10 mb-6">Who It Is For</h2>
                    <ul class="list-disc pl-5 space-y-2 text-slate-600">
                        <li>Corporate Training Teams</li>
                        <li>Educational Institutions</li>
                        <li>Professional Associations</li>
                        <li>Course Creators</li>
                    </ul>
                </div>
                <div>
                    <h2 class="text-3xl font-bold mb-6">Deliverables</h2>
                    <ul class="list-disc pl-5 space-y-2 text-slate-600">
                        <li>Course outlines</li>
                        <li>Storyboards</li>
                        <li>Interactive lessons</li>
                        <li>Assessments & quizzes</li>
                        <li>Learner activities</li>
                        <li>LMS-ready packages</li>
                        <li>Facilitator/learner resources</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="py-20 bg-slate-50 text-center">
            <div class="max-w-4xl mx-auto px-4">
                <h2 class="text-3xl font-bold mb-6">Process & FAQs</h2>
                <p class="text-slate-600 mb-8">Our process starts with a thorough Discovery phase, moving through Strategy, Development, Review, and Launch. Contact us to learn more about timelines and specific requirements.</p>
                <a href="/contact/" class="bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700">Contact Us</a>
            </div>
        </section>

</Layout>
