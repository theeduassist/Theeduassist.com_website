---
import Layout from "../../layouts/Layout.astro";
import HomeHero from "../../components/sections/HomeHero.astro";
import ServiceCategoryTabs from "../../components/sections/ServiceCategoryTabs.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
import { professionalServiceSchema, breadcrumbSchema } from '../../lib/schema';

const jsonLd = [
  professionalServiceSchema(),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Services", urlPath: "/services/" }
  ])
];
---
<Layout
  title="Services Overview"
  description="Explore TheEduAssist's core services, organized by course design, platforms, engagement, and content support."
  canonicalPath="/services/"
  jsonLd={jsonLd}
>

  <HomeHero
    title="Our Services"
    subtitle="We help organizations design, build, and migrate professional eLearning and training experiences. Explore our services below."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
  />

  <ServiceCategoryTabs />

  <FinalCTA
    title="Not sure which service you need?"
    subtitle="Book a free audit to discuss your goals and we'll help you find the right path."
  />

</Layout>
