---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="LMS Implementation & Migration" description="TheEduAssist helps teams set up, organize, migrate, and improve LMS platforms without losing content structure.">

        <section class="py-20 bg-slate-100 text-center px-4">
            <h1 class="text-5xl font-bold text-slate-900 mb-6 max-w-4xl mx-auto leading-tight">LMS Implementation & Migration</h1>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto mb-10">TheEduAssist helps teams set up, organize, migrate, and improve LMS platforms without losing content structure, learner experience, or operational clarity.</p>
            <a href="/book-free-audit/" class="bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700">Book Free Audit</a>
        </section>

        <section class="py-20 bg-white">
            <div class="max-w-4xl mx-auto px-4">
                <h2 class="text-3xl font-bold mb-6">What We Help With</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-slate-600">
                    <div>
                        <h3 class="font-bold text-slate-900 mb-2">Migration Support</h3>
                        <p>Moving your data securely from an old system to a new one seamlessly.</p>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 mb-2">Setup and Configuration</h3>
                        <p>Configuring settings, roles, and permissions to match your operational needs.</p>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 mb-2">Content Organization</h3>
                        <p>Restructuring categories and learning paths for better user experience.</p>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 mb-2">Testing and Launch</h3>
                        <p>Ensuring everything works perfectly before your learners log in.</p>
                    </div>
                </div>

                <h2 class="text-3xl font-bold mt-16 mb-6">Platforms We Support</h2>
                <p class="text-slate-600">Moodle, Tutor LMS, LearnWorlds, Docebo, WordPress LMS, and other leading LMS platforms.</p>
            </div>
        </section>

</Layout>
