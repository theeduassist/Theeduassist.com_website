---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Terms and Conditions" description="Terms and Conditions for TheEduAssist.">

        <section class="py-20 bg-white px-4">
            <div class="max-w-4xl mx-auto">
                <h1 class="text-4xl font-bold text-slate-900 mb-8">Terms and Conditions</h1>
                <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
                    <p class="text-yellow-800 font-medium">Disclaimer: This page is a general placeholder and should be reviewed by a legal professional before launch.</p>
                </div>
                <div class="prose prose-slate max-w-none text-slate-600">
                    <p>Welcome to TheEduAssist. These terms and conditions outline the rules and regulations for the use of TheEduAssist's Website and services.</p>
                    <h2 class="text-2xl font-bold text-slate-900 mt-8 mb-4">Acceptance of Terms</h2>
                    <p>By accessing this website we assume you accept these terms and conditions. Do not continue to use TheEduAssist if you do not agree to take all of the terms and conditions stated on this page.</p>
                </div>
            </div>
        </section>

</Layout>
