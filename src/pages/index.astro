---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import ToolsLogoSlider from "../components/sections/ToolsLogoSlider.astro";
import PlatformStrip from "../components/sections/PlatformStrip.astro";
import CoreServicesGrid from "../components/sections/CoreServicesGrid.astro";
import KajabiHighlight from "../components/sections/KajabiHighlight.astro";
import ComparisonBlock from "../components/sections/ComparisonBlock.astro";
import TrainingSolutionsGrid from "../components/sections/TrainingSolutionsGrid.astro";
import WhyTheEduAssist from "../components/sections/WhyTheEduAssist.astro";
import ProcessTimeline from "../components/sections/ProcessTimeline.astro";
import CaseStudyPreviewGrid from "../components/sections/CaseStudyPreviewGrid.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";
import { process } from '../data/process';
import { organizationSchema, websiteSchema, professionalServiceSchema } from '../lib/schema';
import { getPlatformsForBadges } from '../sanity/queries';

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema()
];

const tools = await getPlatformsForBadges();
---
<Layout
  title="Custom eLearning, Kajabi, and LMS Solutions"
  description="TheEduAssist helps coaches, businesses, training teams, and educational organizations turn content into engaging online learning experiences."
  jsonLd={jsonLd}
>

  <HomeHero
    title="Design, Build, and Launch Better Online Learning Systems"
    subtitle="TheEduAssist helps coaches, course creators, educators, and training teams turn content into structured learning experiences across LMS platforms, Kajabi, course websites, AI-supported workflows, and digital training systems."
    heroBadge="Multi-Platform E-Learning Design Agency"
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
    secondaryCtaLabel="Explore Services"
    secondaryCtaLink="/services/"
    tertiaryCtaLabel="Explore Kajabi Services"
    tertiaryCtaLink="/kajabi-services/"
  />

  <ToolsLogoSlider tools={tools} />

  <CoreServicesGrid />

  <KajabiHighlight />

  <ComparisonBlock />

  <TrainingSolutionsGrid />

  <WhyTheEduAssist />

  <ProcessTimeline steps={process} />

  <CaseStudyPreviewGrid />

  <FinalCTA />

</Layout>
