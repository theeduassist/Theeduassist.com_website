---
import Layout from "../layouts/Layout.astro";
import NewHomeHero from "../components/sections/NewHomeHero.astro";
import WhoWeHelp from "../components/sections/WhoWeHelp.astro";
import CoreServicesNew from "../components/sections/CoreServicesNew.astro";
import AIAssistance from "../components/sections/AIAssistance.astro";
import KajabiSpecialtyNew from "../components/sections/KajabiSpecialtyNew.astro";
import ProcessTimelineNew from "../components/sections/ProcessTimelineNew.astro";
import InfographicSystemNew from "../components/sections/InfographicSystemNew.astro";
import WhyChooseUs from "../components/sections/WhyChooseUs.astro";
import NewHomeFinalCTA from "../components/sections/NewHomeFinalCTA.astro";
import { organizationSchema, websiteSchema, professionalServiceSchema } from '../lib/schema';

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema()
];
---
<Layout
  title="TheEduAssist | E-Learning Design Agency for Courses, Kajabi & LMS Builds"
  description="TheEduAssist helps creators, coaches, educators, consultants, training companies, and businesses build online courses, Kajabi systems, LMS experiences, funnels, automations, and launch-ready e-learning content."
  jsonLd={jsonLd}
>

  <NewHomeHero
    title="Build a Launch-Ready Online Learning System From Your Expertise"
    subtitle="TheEduAssist helps creators, coaches, educators, consultants, training companies, and online academies design courses, build Kajabi systems, migrate LMS content, create learning assets, and launch professional e-learning experiences."
    primaryCtaLabel="Book a Free Course Audit"
    primaryCtaLink="/book-free-audit/"
    secondaryCtaLabel="Explore Services"
    secondaryCtaLink="/services/"
    trustChips={["Course Design", "Kajabi Builds", "LMS Migration", "AI Assistance", "Funnels & Automation"]}
  />

  <WhoWeHelp />

  <CoreServicesNew />

  <AIAssistance />

  <KajabiSpecialtyNew />

  <ProcessTimelineNew />

  <InfographicSystemNew />

  <WhyChooseUs />

  <NewHomeFinalCTA />

</Layout>
