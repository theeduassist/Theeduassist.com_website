---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import ToolsPlatformSection from "../components/sections/ToolsPlatformSection.astro";
import ChooseYourPath from "../components/sections/ChooseYourPath.astro";
import HomeServicesGrid from "../components/sections/HomeServicesGrid.astro";
import PlatformSystemInfographic from "../components/sections/PlatformSystemInfographic.astro";
import KajabiSupportedPlatform from "../components/sections/KajabiSupportedPlatform.astro";
import LearningWorkflow from "../components/sections/LearningWorkflow.astro";
import HomeProofCards from "../components/sections/HomeProofCards.astro";
import HomeBlogPreview from "../components/sections/HomeBlogPreview.astro";
import HomeFinalCTA from "../components/sections/HomeFinalCTA.astro";
import { organizationSchema, websiteSchema, professionalServiceSchema } from '../lib/schema';

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema()
];
---
<Layout
  title="Custom eLearning, Kajabi, and LMS Solutions"
  description="TheEduAssist helps coaches, businesses, training teams, and educational organizations turn content into engaging online learning experiences."
  jsonLd={jsonLd}
>

  <HomeHero
    title="Design, Build, and Launch Better Online Learning Systems"
    subtitle="TheEduAssist helps coaches, course creators, educators, and training teams turn content into structured learning experiences across LMS platforms, Kajabi, course websites, AI-supported workflows, and digital training systems."
    heroBadge="Multi-Platform E-Learning Design Agency"
    trustText="Course strategy, content flow, LMS setup, Kajabi builds, platform migration, automation, testing, and launch support."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
    secondaryCtaLabel="Explore Services"
    secondaryCtaLink="/services/"
    tertiaryCtaLabel="Explore Kajabi Services"
    tertiaryCtaLink="/kajabi-services/"
    showDashboardVisual={true}
  />

  <ToolsPlatformSection />

  <ChooseYourPath />

  <HomeServicesGrid />

  <PlatformSystemInfographic />

  <LearningWorkflow />

  <KajabiSupportedPlatform />

  <HomeProofCards />

  <HomeBlogPreview />

  <HomeFinalCTA />

</Layout>
