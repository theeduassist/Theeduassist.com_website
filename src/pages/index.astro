---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import ToolsLogoSlider from "../components/sections/ToolsLogoSlider.astro";
import ChooseYourPath from "../components/sections/ChooseYourPath.astro";
import HomeServicesGrid from "../components/sections/HomeServicesGrid.astro";
import HomeKajabiHighlight from "../components/sections/HomeKajabiHighlight.astro";
import LearningSystemInfographic from "../components/sections/LearningSystemInfographic.astro";
import OnlineAcademyCTA from "../components/sections/OnlineAcademyCTA.astro";
import HomeCaseStudyProof from "../components/sections/HomeCaseStudyProof.astro";
import HomeBlogPreview from "../components/sections/HomeBlogPreview.astro";
import HomeFinalCTA from "../components/sections/HomeFinalCTA.astro";
import { organizationSchema, websiteSchema, professionalServiceSchema } from '../lib/schema';

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  professionalServiceSchema()
];
---
<Layout
  title="Custom eLearning, Kajabi, and LMS Solutions | TheEduAssist"
  description="TheEduAssist helps coaches, course creators, educators, and training teams turn content into structured online learning experiences."
  jsonLd={jsonLd}
>

  <HomeHero />

  <ToolsLogoSlider />

  <ChooseYourPath />

  <HomeServicesGrid />

  <HomeKajabiHighlight />

  <LearningSystemInfographic />

  <OnlineAcademyCTA />

  <HomeCaseStudyProof />

  <HomeBlogPreview />

  <HomeFinalCTA />

</Layout>
