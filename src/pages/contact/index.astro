---
import Layout from "../../layouts/Layout.astro";
import ContactHero from "../../components/contact/ContactHero.astro";
import ContactOptions from "../../components/contact/ContactOptions.astro";
import QuickContactForm from "../../components/forms/QuickContactForm.astro";
import ContactFAQ from "../../components/contact/ContactFAQ.astro";
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';

const jsonLd = [
  webPageSchema(
    "Contact TheEduAssist | E-Learning Design Agency",
    "Contact TheEduAssist for online course creation, Kajabi setup, LMS migration, AI-powered e-learning support, content conversion, funnels, automation, and course launch support.",
    "/contact/"
  ),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Contact", urlPath: "/contact/" }
  ])
];

const trustChips = [
  "Course Creation",
  "Kajabi Setup",
  "LMS Migration",
  "AI E-Learning Support",
  "Content Conversion",
  "Funnels & Automation"
];
---
<Layout
  title="Contact TheEduAssist | E-Learning Design Agency"
  description="Contact TheEduAssist for online course creation, Kajabi setup, LMS migration, AI-powered e-learning support, content conversion, funnels, automation, and course launch support."
  canonicalPath="/contact/"
  jsonLd={jsonLd}
>

  <ContactHero
    title="Contact TheEduAssist"
    subtitle="Have a course idea, Kajabi setup, LMS migration, training content, or online learning system that needs structure? Contact TheEduAssist and we’ll help you find the right next step."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
    secondaryCtaLabel="Email Us"
    secondaryCtaLink="mailto:Info@theeduassist.com"
    email="Info@theeduassist.com"
    trustChips={trustChips}
  />

  <ContactOptions email="Info@theeduassist.com" />

  <section class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-white p-8 md:p-10 rounded-xl border border-slate-200 shadow-sm">
        <h2 class="text-3xl font-bold mb-8 text-slate-900 text-center">Send a Quick Message</h2>
        <QuickContactForm />
      </div>
    </div>
  </section>

  <ContactFAQ />

</Layout>
