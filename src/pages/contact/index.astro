---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Contact Us" description="Get in touch with TheEduAssist for custom eLearning and LMS solutions.">

        <section class="py-20 bg-slate-100 text-center px-4">
            <h1 class="text-5xl font-bold text-slate-900 mb-6 max-w-4xl mx-auto">Contact TheEduAssist</h1>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto mb-10">We're here to help structure, build, or migrate your learning content.</p>
            <p class="text-lg font-medium">Email: <a href="mailto:info@theeduassist.com" class="text-blue-600 underline">info@theeduassist.com</a></p>
        </section>

        <section class="py-20 bg-white">
            <div class="max-w-2xl mx-auto px-4 bg-slate-50 p-8 rounded-lg border border-slate-200">
                <h2 class="text-2xl font-bold mb-6">Send us a message</h2>
                <p class="text-sm text-slate-500 mb-6 italic">Note: The form backend will be connected later. Please email us directly or book an audit.</p>

                <form class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Name</label>
                            <input type="text" class="w-full border border-slate-300 rounded p-2" placeholder="Your Name" disabled />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                            <input type="email" class="w-full border border-slate-300 rounded p-2" placeholder="Your Email" disabled />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Company</label>
                            <input type="text" class="w-full border border-slate-300 rounded p-2" placeholder="Company Name" disabled />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Website</label>
                            <input type="url" class="w-full border border-slate-300 rounded p-2" placeholder="Website URL" disabled />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Service Needed</label>
                        <input type="text" class="w-full border border-slate-300 rounded p-2" placeholder="e.g., Kajabi Setup, LMS Migration" disabled />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Budget Range</label>
                            <input type="text" class="w-full border border-slate-300 rounded p-2" placeholder="Estimated Budget" disabled />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Timeline</label>
                            <input type="text" class="w-full border border-slate-300 rounded p-2" placeholder="Expected Timeline" disabled />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Message</label>
                        <textarea class="w-full border border-slate-300 rounded p-2 h-32" placeholder="How can we help?" disabled></textarea>
                    </div>

                    <button type="button" class="bg-slate-300 text-slate-500 px-6 py-3 rounded-md font-medium cursor-not-allowed w-full">Submit</button>
                </form>

                <div class="mt-8 text-center border-t border-slate-200 pt-8">
                    <h3 class="text-lg font-bold mb-4">Prefer a direct conversation?</h3>
                    <a href="/book-free-audit/" class="inline-block bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700">Book Free Audit</a>
                </div>
            </div>
        </section>

</Layout>
