---
import Layout from "../../layouts/Layout.astro";
import HomeHero from "../../components/sections/HomeHero.astro";
import CalendlySoftCTA from "../../components/sections/CalendlySoftCTA.astro";
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';

const jsonLd = [
  webPageSchema(
    "Contact Us",
    "Get in touch with TheEduAssist for custom eLearning and LMS solutions.",
    "/contact/"
  ),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Contact", urlPath: "/contact/" }
  ])
];
---
<Layout
  title="Contact Us"
  description="Get in touch with TheEduAssist for custom eLearning and LMS solutions."
  canonicalPath="/contact/"
  jsonLd={jsonLd}
>

  <HomeHero
    title="Contact TheEduAssist"
    subtitle="We're here to help structure, build, or migrate your learning content."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
  />

  <section class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-slate-50 p-8 md:p-10 rounded-lg border border-slate-200 shadow-sm">
        <h2 class="text-2xl font-bold mb-6 text-slate-900">Send us a message</h2>

        <div class="mb-8 p-4 bg-blue-50 text-blue-800 rounded-md border border-blue-100 flex items-start">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <div>
            <p class="font-medium">Direct Email</p>
            <p class="text-sm mt-1">You can reach us directly at <a href="mailto:info@theeduassist.com" class="font-bold underline hover:text-blue-600">info@theeduassist.com</a></p>
          </div>
        </div>

        <p class="text-sm text-slate-500 mb-6 italic">Note: The form backend will be connected in a future phase. Please email us directly or book an audit call.</p>

        <form class="space-y-5 opacity-70">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Name</label>
              <input type="text" class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Your Name" disabled />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
              <input type="email" class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Your Email" disabled />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Company</label>
              <input type="text" class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Company Name" disabled />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Website</label>
              <input type="url" class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Website URL" disabled />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Service Needed</label>
            <select class="w-full border border-slate-300 rounded-md p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" disabled>
              <option value="">Select a service...</option>
              <option value="kajabi">Kajabi Services</option>
              <option value="lms">LMS Implementation & Migration</option>
              <option value="custom">Custom eLearning Development</option>
              <option value="ai">AI-Powered eLearning</option>
              <option value="other">Other / Not sure</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Message</label>
            <textarea class="w-full border border-slate-300 rounded-md p-2.5 h-32 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="How can we help?" disabled></textarea>
          </div>

          <p class="text-xs text-slate-500">By submitting this form, you agree to our Privacy Policy.</p>

          <button type="button" class="bg-slate-300 text-slate-500 px-6 py-3 rounded-md font-medium cursor-not-allowed w-full md:w-auto">Submit Message</button>
        </form>

        <CalendlySoftCTA />
      </div>
    </div>
  </section>

</Layout>
