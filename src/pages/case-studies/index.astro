---
import Layout from "../../layouts/Layout.astro";
import { caseStudies } from '../../data/caseStudies';
---
<Layout title="Case Studies" description="Read how TheEduAssist has helped clients build successful eLearning solutions.">

        <section class="py-20 bg-slate-100 text-center px-4">
            <h1 class="text-5xl font-bold text-slate-900 mb-6 max-w-4xl mx-auto">Case Studies</h1>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto mb-10">Explore our professional work in custom eLearning, LMS setup, and instructional design.</p>
        </section>

        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">

                {caseStudies.map(cs => (
                    <div class="border border-slate-200 rounded-lg p-8 shadow-sm">
                        <div class="text-sm font-bold tracking-wider text-blue-600 uppercase mb-3">Client Type: {cs.clientType}</div>
                        <h2 class="text-2xl font-bold mb-4">{cs.title}</h2>
                        <p class="text-slate-600 mb-6">{cs.summary}</p>
                        <p class="text-xs text-slate-400 italic">Note: {cs.note}</p>
                    </div>
                ))}

            </div>
        </section>

        <section class="py-16 bg-slate-50 text-center">
            <a href="/book-free-audit/" class="bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700">Book Free Audit</a>
        </section>

</Layout>
